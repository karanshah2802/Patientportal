<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<style>
    /* Disable <a> buttons */
    .a-disabled {
        pointer-events: none; /* Prevent click */
        opacity: 0.5; /* Make it look disabled */
    }
</style>

<script>
    $(document).ready(function () {
        const $phoneInput = $('#pi-phoneno');
        const $verifyBtn = $('#verify-btn');
        const $otpModal = new bootstrap.Modal(document.getElementById('otpModal'));
        const $otpInput = $('#otp-input');
        const $otpSubmitBtn = $('#otp-submit-btn');
        const $saveBtn = $('#save-btn');

        // Initially disable Save button and hide Verify button
        $saveBtn.addClass('a-disabled');
        $verifyBtn.addClass('d-none');

        $phoneInput.on('input', function () {
            // Hide Verify button on any input change
            $verifyBtn.addClass('d-none');

            // Disable Save whenever phone input changes
            $saveBtn.addClass('a-disabled');

            // Show Verify button only if 10-digit number
            const val = $(this).val();
            if (val.length === 10 && /^\d{10}$/.test(val)) {
                $verifyBtn.removeClass('d-none');
                $verifyBtn.removeClass('a-disabled'); // enable Save
            }
        });

        $verifyBtn.on('click', function () {
            const mobile = $phoneInput.val();
            $.ajax({
                url: '/Appointment?handler=SendOTP',
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ Mobile: mobile }),
                success: function (res) {
                    if (res.success) {
                        $otpInput.val('');
                        $('#otp-msg').text('');
                        $otpSubmitBtn.prop('disabled', true);
                        $verifyBtn.addClass('a-disabled'); // enable Save
                        $otpModal.show();
                    } else {
                        $('#pi-phoneno-msg').text(res.message);
                    }
                }
            });
        });

        $otpInput.on('input', function () {
            const val = $(this).val();
            $otpSubmitBtn.prop('disabled', !(val.length >= 4 && val.length <= 6));
        });

        $otpSubmitBtn.on('click', function () {
            const mobile = $phoneInput.val();
            const otp = $otpInput.val();
            $.ajax({
                url: '/Appointment?handler=VerifyOTP',
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ Mobile: mobile, OTP: otp }),
                success: function (res) {
                    if (res.success) {
                        $('#otp-msg').text(res.message);
                        $otpModal.hide();
                        $saveBtn.removeClass('a-disabled'); // enable Save
                        $verifyBtn.addClass('a-disabled'); // enable Save
                        toastr.success("OTP Verifyed successfully!"); // Show success message
                    } else {
                        $('#otp-msg').text(res.message);


                        $saveBtn.addClass('a-disabled'); // keep disabled
                    }
                }
            });
        });
    });
</script>


