<script>
    (function () {
        var APPT_IN_PERSON = 'Dr. Sejal In-person Consultation';
        var APPT_ONLINE = 'Dr. Sejal Online Consultation';
        var APPT_PROCEDURES = 'Appointment Request for Procedures';
        var __lastAppointmentType = '';

        function computeManualMinDateTime() {
            var d = new Date();
            d.setTime(d.getTime() + 60 * 60 * 1000);
            var mins = d.getMinutes();
            var rem = mins % 15;
            if (rem !== 0) {
                d.setMinutes(mins + (15 - rem), 0, 0);
            } else {
                d.setSeconds(0, 0);
            }
            return d;
        }
        window.__appointmentPortalComputeManualMin = computeManualMinDateTime;

        function isAppointmentTypeSelected(t) {
            return t === APPT_IN_PERSON || t === APPT_ONLINE || t === APPT_PROCEDURES;
        }

        window.onAppointmentTypeChange = function (args) {
            var wrap = document.getElementById('pi-resched-dtp-wrap');
            var dateTimePickerEl = document.getElementById('pi-resched');
            if (!dateTimePickerEl || !dateTimePickerEl.ej2_instances || !dateTimePickerEl.ej2_instances[0]) return;
            var dateTimePicker = dateTimePickerEl.ej2_instances[0];
