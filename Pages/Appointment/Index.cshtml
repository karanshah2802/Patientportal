@page
@model Patientportal.Pages.Appointment.IndexModel
@using System.Globalization
@using System.Text.Json
@using Patientportal.Model
@{
    List<string> FormofAppointment = new List<string> { "Dr. Sejal In-person Consultation", "Dr. Sejal Online Consultation", "Appointment Request for Procedures" };
    var appointmentSlotScheduleInitialData = new List<AppointmentListItem>();
    var portalNumericId = Model.LoggedInProfileId > 0
        ? Model.LoggedInProfileId
        : (Model.PortalPatientProfile != null && Model.PortalPatientProfile.Id > 0 ? Model.PortalPatientProfile.Id : 0L);
    var portalProfileId = portalNumericId > 0
        ? portalNumericId.ToString(CultureInfo.InvariantCulture)
        : "0";
    var showPortalAppointmentFor = Model.IsPatientPortalBooking
        && Model.PortalBookingSubjects.Count > 0;
    var portalDependentsDmUrl = $"/Appointment/Index?handler=PortalDependents&profileId={portalProfileId}";
    var portalDependentsDmUrlJson = JsonSerializer.Serialize(portalDependentsDmUrl);
    var portalDependentsCardUrl = $"/Appointment/Index?handler=PortalDependentsCard&profileId={portalProfileId}";
    var portalDependentsCardUrlJson = JsonSerializer.Serialize(portalDependentsCardUrl);
    var postAppointmentRedirectUrl = !string.IsNullOrEmpty(Model.LoggedInEncryptedPatientId)
        ? Url.Page("/Patient/Index", new { id = Model.LoggedInEncryptedPatientId })
        : "https://www.inurskn.in/";
    if (string.IsNullOrEmpty(postAppointmentRedirectUrl))
        postAppointmentRedirectUrl = "https://www.inurskn.in/";
    var postAppointmentRedirectUrlJson = JsonSerializer.Serialize(postAppointmentRedirectUrl);
    var appointmentCancelPatientUrl = !string.IsNullOrEmpty(Model.LoggedInEncryptedPatientId)
        ? Url.Page("/Patient/Index", new { id = Model.LoggedInEncryptedPatientId })
        : "";
    var appointmentCancelPatientUrlJson = JsonSerializer.Serialize(appointmentCancelPatientUrl);
    var isLoggedInForAppointmentCancel = !string.IsNullOrEmpty(Model.LoggedInEncryptedPatientId);
}
@* @{
    ViewData["Title"] = "Appointment";
    Layout = "_LayoutMainAppoinment";
} *@
<style>
    .a-disabled {
        pointer-events: none; /* Prevent click */
        opacity: 0.5; /* Make it look disabled */
    }

    .a-disabled {
        pointer-events: none; /* Prevent click */
        opacity: 0.5; /* Make it look disabled */
    }

    input.form-control[readonly], textarea[readonly] {
        background-color: #f8f9fa;
        cursor: not-allowed;
    }

    /* Do NOT use Bootstrap .input-group here — it uses flex-wrap:wrap and breaks EJ2 onto multiple rows.
       Match IUSApp scheduler overlay; force one horizontal row inside Material / EJ2 datetimepicker. */
    /* EJ2 date + time icons: compact 30px cells, gap:0; scheduler sits just left of the pair */
    .datetimepicker-container.appointment-portal-dtp {
        position: relative;
        display: block;
        width: 100%;
        min-height: 45px;
        border-bottom: 1px solid #ced4da;
        padding-bottom: 4px;
    }

    .datetimepicker-container.appointment-portal-dtp .appointment-dtp-ejs,
    .datetimepicker-container.appointment-portal-dtp #pi-resched {
        width: 100% !important;
        max-width: 100%;
        display: block !important;
    }

    .datetimepicker-container.appointment-portal-dtp .e-datetime-wrapper,
    .datetimepicker-container.appointment-portal-dtp .e-float-input.e-input-group,
    .datetimepicker-container.appointment-portal-dtp .e-input-group.e-control-wrapper,
    .datetimepicker-container.appointment-portal-dtp .e-input-group {
        display: flex !important;
        flex-direction: row !important;
        flex-wrap: nowrap !important;
        align-items: center !important;
        gap: 0 !important;
        column-gap: 0 !important;
        border: none !important;
        border-radius: 0 !important;
        background: transparent !important;
        box-shadow: none !important;
        width: 100% !important;
    }

    .datetimepicker-container.appointment-portal-dtp .e-input-group .e-input:not(textarea) {
        flex: 1 1 0% !important;
        min-width: 0 !important;
        width: auto !important;
        height: 45px !important;
        line-height: 43px !important;
        padding-top: 0 !important;
        padding-bottom: 0 !important;
        padding-left: 0.5rem !important;
        /* ~3 compact icon slots (30px) + small buffer */
        padding-right: 6.25rem !important;
        box-sizing: border-box !important;
        vertical-align: middle !important;
    }

    .datetimepicker-container.appointment-portal-dtp .e-input-group .e-input-group-icon {
        flex-shrink: 0 !important;
        align-self: stretch !important;
        float: none !important;
        border: none !important;
        width: 30px !important;
        min-width: 30px !important;
        max-width: 30px !important;
        height: 45px !important;
        min-height: 45px !important;
        margin: 0 !important;
        padding: 0 !important;
        display: inline-flex !important;
        align-items: center !important;
        justify-content: center !important;
        box-sizing: border-box !important;
    }

    .datetimepicker-container.appointment-portal-dtp span.e-input-group-icon.e-date-icon.e-icons {
        border: none;
    }

    .appointment-portal-dtp .scheduler-icon {
        position: absolute !important;
        /* Tight pack: 30px time + 30px date + 2px gap — scheduler sits just left of date icon */
        right: 62px;
        top: 0;
        height: 45px !important;
        width: 30px !important;
        min-width: 30px !important;
        max-width: 30px !important;
        margin: 0 !important;
        padding: 0 !important;
        cursor: pointer;
        z-index: 11;
        background: none !important;
        border: none !important;
        line-height: 1;
        box-shadow: none !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        box-sizing: border-box !important;
    }

    .appointment-portal-dtp .scheduler-icon:hover i {
        color: #0061AB;
    }

    .appointment-portal-dtp .scheduler-icon i {
        font-size: 1.1rem;
        color: #495057;
        line-height: 1;
        vertical-align: middle;
    }

    /* In-person: date/time only via scheduler — block input and built-in date/time icons */
    .datetimepicker-container.appointment-portal-dtp.scheduler-only-pick .e-input-group .e-input:not(textarea),
    .datetimepicker-container.appointment-portal-dtp.scheduler-only-pick .e-input-group .e-input-group-icon {
        pointer-events: none !important;
        cursor: default !important;
    }

    /* No appointment type yet: block datetime picker and scheduler button */
    .datetimepicker-container.appointment-portal-dtp.appt-datetime-disabled .e-input-group .e-input:not(textarea),
    .datetimepicker-container.appointment-portal-dtp.appt-datetime-disabled .e-input-group .e-input-group-icon,
    .datetimepicker-container.appointment-portal-dtp.appt-datetime-disabled .scheduler-icon {
        pointer-events: none !important;
        cursor: not-allowed !important;
    }

    .datetimepicker-container.appointment-portal-dtp.appt-datetime-disabled .scheduler-icon {
        opacity: 0.45;
    }

    .appointment-schedule-modal-wrap {
        height: calc(100vh - 56px);
        min-height: calc(100vh - 56px);
        width: 100%;
        display: flex;
        flex-direction: column;
    }

    .appointment-schedule-modal-wrap .schedule-wrapper-modal {
        flex: 1 1 auto;
        min-height: 0;
        width: 100%;
        display: flex;
        flex-direction: column;
    }

    .appointment-schedule-modal-wrap .e-schedule {
        flex: 1 1 auto;
        min-height: 0;
    }

    #appointmentSlotModal .modal-dialog.modal-fullscreen {
        height: 100vh;
        max-height: 100vh;
    }

    #appointmentSlotModal .modal-content {
        min-height: 100vh;
        height: 100%;
        border-radius: 0;
        border: none;
    }

    #appointmentSlotModal .modal-header {
        flex-shrink: 0;
    }

    #appointmentSlotModal .modal-body {
        flex: 1 1 auto;
        min-height: 0;
        overflow: hidden;
    }

    /* Explicit fill + text so busy slots always match (not dependent on theme / read-only parent). */
    .appointment-schedule-modal-wrap .blocked-slot {
        background-color: #7AB6E0;
        color: #fff;
        text-align: center;
        font-weight: 600;
        padding: 5px 6px;
        border-radius: 4px;
        box-sizing: border-box;
        min-height: 100%;
        width: 100%;
        line-height: 1.25;
    }

    .appointment-schedule-modal-wrap .e-schedule .e-hide-childs > * {
        display: flex !important;
        flex-direction: column !important;
        align-items: stretch !important;
        min-height: 100% !important;
        height: 100% !important;
    }

    .appointment-schedule-modal-wrap .e-appointment.e-read-only {
        background: #7AB6E0 !important;
    }

    /* Leave / holiday: keep #e9ecef family but full opacity, neutral text, subtle depth (pairs with .blocked-slot blue). */
    .appointment-schedule-modal-wrap .doctor-leave-cell {
        background: linear-gradient(180deg, #f4f6f8 0%, #e9ecef 45%, #e3e7eb 100%) !important;
        color: #7AB6E0 !important;
        pointer-events: none;
        opacity: 1 !important;
        box-shadow: inset 0 0 0 1px rgba(0, 97, 171, 0.06);
    }

    .appointment-schedule-modal-wrap .holiday-cell {
        background: linear-gradient(180deg, #eceef1 0%, #dee2e6 50%, #d8dce0 100%) !important;
        color: #495057 !important;
        pointer-events: none;
        opacity: 1 !important;
        box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.05);
    }

    .appointment-schedule-modal-wrap .e-quick-popup-wrapper.e-lib.e-popup.e-control.e-popup-open {
        display: none;
    }

    .appointment-schedule-modal-wrap .e-current-time {
        display: none;
    }

    .appointment-schedule-modal-wrap .e-header-cells {
        pointer-events: none;
    }

    /* Add Dependent Patient modal */
    #addDependentAppointmentModal .modal-dialog {
        max-width: 520px;
    }

    #addDependentAppointmentModal .modal-content {
        border-radius: 14px;
        border: none;
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.14);
        overflow: hidden;
    }

    #addDependentAppointmentModal .modal-header {
        border-bottom: 1px solid #e9ecef;
        padding: 1.1rem 1.35rem;
    }

    #addDependentAppointmentModal .modal-title {
        font-weight: 600;
        font-size: 1.15rem;
        color: #212529;
    }

    #addDependentAppointmentModal .modal-body {
        padding: 1.25rem 1.35rem 1.5rem;
    }

    #addDependentAppointmentModal .modal-footer {
        border-top: 1px solid #e9ecef;
        padding: 1rem 1.35rem;
        gap: 0.5rem;
        display: flex;
        flex-wrap: nowrap;
        justify-content: flex-end;
        align-items: center;
        width: 100%;
    }

    .portal-dependent-toolbar {
        width: 100%;
    }

    #addDependentAppointmentModal .form-label {
        font-weight: 500;
        color: #495057;
        margin-bottom: 0.4rem;
    }

    #addDependentAppointmentModal .dependent-modal-text {
        border-radius: 10px;
        min-height: 45px;
    }

    /* Gender / Relation dropdowns: rounded, blue border, red bottom accent */
    #addDependentAppointmentModal .dependent-modal-ddl.e-ddl .e-input-group.e-control-wrapper {
        border: 1px solid #5b9bd5 !important;
        border-radius: 10px !important;
        border-bottom: 2px solid #c62828 !important;
        min-height: 45px;
        background: #fff !important;
    }

    #addDependentAppointmentModal .dependent-modal-ddl.e-ddl.e-input-focus .e-input-group.e-control-wrapper {
        box-shadow: 0 0 0 2px rgba(91, 155, 213, 0.28);
    }

    #addDependentAppointmentModal .dependent-modal-ddl .e-input {
        font-size: 0.95rem;
    }

    /* EJ2 dropdown list opens in body — keep above Bootstrap modal (1055) */
    body > .e-ddl.e-popup-open {
        z-index: 2000 !important;
    }

    /* Portal dependents grid: compact Edit button + small vertical margin (row stays 38px) */
    #GridPortalDependents .portal-dep-edit-btn {
        display: inline-block;
        margin: 4px 0;
        padding: 1px 8px !important;
        font-size: 0.8125rem;
        line-height: 1.2;
        min-height: 0;
        border-radius: 6px;
    }
    #GridPortalDependents .e-rowcell:has(.portal-dep-edit-btn) {
        padding-top: 0;
        padding-bottom: 0;
        vertical-align: middle;
        min-width: 120px;
        overflow: visible;
    }

    /* Mobile: dependent cards — same visual language as Patient portal appointment cards */
    #portal-dependents-container .portal-dep-mobile-card {
        background-color: #f4f6f9;
        border: 1px solid #d8dee6;
        border-radius: var(--formradius, 10px);
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
    }
    #portal-dependents-container .portal-dep-mobile-card .ius-appbody {
        align-items: flex-start;
        border-bottom-color: #c5cdd8;
        padding-bottom: 14px;
        margin-bottom: 14px;
    }
    #portal-dependents-container .portal-dep-mobile-card .ius-appinfo h3 {
        font-family: 'manrope-sb', sans-serif;
        font-size: 1.125rem;
        line-height: 1.35;
        color: #1a1a2e;
        word-break: break-word;
        margin: 0;
    }
    #portal-dependents-container .portal-dep-mobile-card .ius-apptyfo {
        margin-top: 8px;
        font-size: 0.875rem;
        color: #1a1a2e;
    }
    #portal-dependents-container .portal-dep-mobile-card .ius-ctrls {
        flex-shrink: 0;
        padding-top: 2px;
    }
    #portal-dependents-container .portal-dep-mobile-edit-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border: none;
        border-radius: 10px;
        background: transparent;
        color: #0061ab;
        font-size: 1.15rem;
        line-height: 1;
        padding: 0;
        cursor: pointer;
        transition: color 0.15s ease, background-color 0.15s ease;
    }
    #portal-dependents-container .portal-dep-mobile-edit-icon:hover {
        color: #004d8c;
        background-color: rgba(0, 97, 171, 0.08);
    }
    #portal-dependents-container .portal-dep-mobile-edit-icon:focus-visible {
        outline: 2px solid #0061ab;
        outline-offset: 2px;
    }
    #portal-dependents-container .portal-dep-mobile-card .ius-foo {
        align-items: flex-end;
    }
    #portal-dependents-container .portal-dep-mobile-card .ius-datetime > div:not(.datetime-label) {
        font-size: 1rem;
        font-family: 'manrope-md', sans-serif;
        color: #1a1a2e;
        margin-top: 4px;
        line-height: 1.35;
    }
    #portal-dependents-container .portal-dep-mobile-card .ius-status .ius-badge {
        font-family: 'manrope-sb', sans-serif;
        font-size: 11px;
        line-height: 1.2;
        padding: 6px 12px;
        border-radius: 6px;
    }
    #portal-dependents-container .portal-dep-mobile-empty {
        padding: 12px 4px;
    }

</style>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Book Appointment · Inurskn - Patient Portal</title>

    <link rel="stylesheet" href="~/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/css/custom.css">
    <link rel="stylesheet" href="~/css/responsive.css">
    <link rel="stylesheet" href="~/app/master.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/masterextended.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/font-awesome/css/all.min.css" />

    <link rel="icon" href="~/favicon.png" type="image/png" asp-append-version="true" />
    <link rel="apple-touch-icon" href="~/favicon.png" asp-append-version="true" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet">

</head>
<body>
    <div class="dashboard d-flex min-vh-100">
        <div class="dashboard__body overflow-hidden flex-grow-1">
            <partial name="_LayoutMainHeader" />
            <main class="">
                <div class="">
    <script>
        window.__isPatientPortalBooking = @(Model.IsPatientPortalBooking ? "true" : "false");
        window.__requirePortalDisplayName = @(Model.RequirePortalDisplayName ? "true" : "false");
        window.__appointmentPatientId = @(Model.IsPatientPortalBooking && portalNumericId > 0 ? portalNumericId.ToString(CultureInfo.InvariantCulture) : "null");
        window.__portalParentProfileId = @(portalNumericId > 0 ? portalNumericId.ToString(CultureInfo.InvariantCulture) : "null");
        window.__portalDependentsProfileId = "@portalProfileId";
        window.__portalDependentsDmUrl = @Html.Raw(portalDependentsDmUrlJson);
        window.__portalDependentsCardUrl = @Html.Raw(portalDependentsCardUrlJson);
        window.__portalBookingSubjects = @Html.Raw(Model.PortalBookingSubjectsJson);
        window.__postAppointmentRedirectUrl = @Html.Raw(postAppointmentRedirectUrlJson);
        window.__appointmentCancelPatientUrl = @Html.Raw(appointmentCancelPatientUrlJson);
        window.__isLoggedInForAppointmentCancel = @(isLoggedInForAppointmentCancel ? "true" : "false");
        window.cleanupAppointmentModalBackdrop = function () {
            function strip() {
                if (document.querySelector(".modal.show")) return;
                document.querySelectorAll(".modal-backdrop").forEach(function (el) { el.remove(); });
                document.body.classList.remove("modal-open");
                document.body.style.removeProperty("padding-right");
                document.body.style.overflow = "";
            }
            strip();
            setTimeout(strip, 50);
            setTimeout(strip, 400);
        };
    </script>
    <main class="page">
        <div class="container container-x">
            <h1 class="page-title text-28">Book Appointment</h1>

            <div class="ius-block ius-card">
                <h2 class="mb-3">Book Appointment</h2>

                <form class="ius-form" action="#" method="POST">
                    <input type="hidden" id="PatientId" name="medicalPatientSignature" class="custom-field-height" value="@(portalNumericId > 0 ? portalNumericId.ToString(CultureInfo.InvariantCulture) : "")" />
                    <div class="row">
                        <div class="col-md-6 col-xl-4">
                            <label for="pi-formofappt" class="form-label">Type of Appointment*</label>
                            <ejs-dropdownlist class="form-control" id="pi-formofappt" style="height:45px;" TValue="string" DataSource="FormofAppointment" Placeholder="Select type of appointment" change="onAppointmentTypeChange"></ejs-dropdownlist>
                            <span id="pi-formofappt-msg" class="text-danger"></span>
                        </div>   
                        <div class="col-md-6 col-xl-4">
                            <label for="pi-resched" class="form-label">Appointment Date &amp; Time*</label>
                            <div id="pi-resched-dtp-wrap" class="datetimepicker-container appointment-portal-dtp" style="position: relative;">
                                <ejs-datetimepicker id="pi-resched" cssClass="appointment-dtp-ejs" step="15" min="DateTime.Today" style="height:45px;" value="@Model.SelectedDateTime?.LocalDateTime" format="@Model.EjsDateTimePattern" placeholder="Select date and time"></ejs-datetimepicker>
                                <button type="button" class="scheduler-icon" id="open-slot-calendar-btn" title="Pick a slot from the full calendar">
                                    <i class="fas fa-calendar-alt" aria-hidden="true"></i>
                                </button>
                            </div>
                            <span id="AppointmentDateSpan" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 col-xl-4">
                            <label for="pi-phoneno" class="form-label">Phone Number*</label>
                            <div class="input-group">
                                <input type="text" name="phoneno" maxlength="10" class="form-control" id="pi-phoneno" value="@Model.PortalPatientProfile?.Mobile" @Html.Raw(Model.IsPatientPortalBooking ? "readonly=\"readonly\"" : "")>
                                <button type="button" class="btn btn-success d-none" id="verify-btn">Verify</button>
                            </div>
                            <span id="pi-phoneno-msg" class="text-danger"></span>
                        </div>

                        @if (showPortalAppointmentFor)
                        {
                            <div class="col-md-6 col-xl-4">
                                <label for="pi-appointment-for" class="form-label">Appointment for*</label>
                                <ejs-dropdownlist id="pi-appointment-for"
                                                  cssClass="form-control"
                                                  style="height: 45px;"
                                                  TValue="long"
                                                  placeholder="Who is this appointment for?"
                                                  dataSource="@Model.PortalBookingSubjects"
                                                  value="@portalNumericId"
                                                  change="onPortalAppointmentSubjectChange">
                                    <e-dropdownlist-fields text="DisplayLabel" value="ProfileId"></e-dropdownlist-fields>
                                </ejs-dropdownlist>
                                <span id="pi-appointment-for-span" class="text-danger"></span>
                            </div>
                            @if (Model.RequirePortalDisplayName)
                            {
                                <div class="col-md-6 col-xl-4">
                                    <label for="pi-portal-display-name" class="form-label">Patient Name*</label>
                                    <input type="text" class="form-control" id="pi-portal-display-name" name="portal_display_name" maxlength="100" autocomplete="name" />
                                    <span id="pi-portal-display-name-span" class="text-danger"></span>
                                </div>
                            }
                        }

                        @if (Model.ShowPortalDependentSection)
                        {
                            @* Email/DOB live in a hidden row; validation errors must show here or users see no feedback when Book fails. *@
                            <div class="col-12">
                                <span id="pi-portal-profile-msg" class="text-danger small d-block mt-1"></span>
                            </div>
                        }

                        @* Portal: Name / Age / Gender / Relation for dependents live in Add/Edit modal (dep-modal-* ids), not on the main row. Dependents UI is a separate card below this form. *@

                        @* Portal: email / DOB / concerns stay in DOM for save API; not shown on main form *@
                        @if (Model.ShowPortalDependentSection)
                        {
                            <div class="row d-none" aria-hidden="true">
                                <div class="col-md-6 col-xl-4">
                                    <label class="form-label">Email ID</label>
                                    <input type="email" class="form-control" id="pi-email" name="email" maxlength="100" value="@Model.PortalPatientProfile?.Email" autocomplete="email" />
                                    <span id="emailidspan" class="text-danger"></span>
                                </div>
                                <div class="col-md-6 col-xl-4">
                                    <label class="form-label">Date of Birth</label>
                                    <ejs-datepicker id="pi-dob" class="form-control" format="dd/MM/yyyy" style="height: 45px;" value="@Model.PortalPatientProfile?.Dob"></ejs-datepicker>
                                    <span id="dobspan" class="text-danger"></span>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Concerns or Requests</label>
                                    <textarea id="pi-notes" name="concerns" maxlength="200" class="form-control" rows="2"></textarea>
                                    <span id="notesspan" class="text-danger"></span>
                                </div>
                            </div>
                        }

                        @* Anonymous OTP flow: hidden row with all fields scripts touch *@
                        @if (Model.IsAnonymousBooking)
                        {
                            <div class="row d-none" aria-hidden="true">
                                <div class="col-md-6">
                                    <input type="text" class="form-control" id="pi-name" name="patientname" maxlength="100" />
                                    <span id="Namespan" class="text-danger"></span>
                                </div>
                                <div class="col-md-6">
                                    <input type="text" class="form-control" id="pi-age" name="age" oninput="validateAge(this)" maxlength="2" />
                                    <span id="agespan" class="text-danger"></span>
                                </div>
                                <div class="col-12">
                                    <div class="btn-group" role="group">
                                        <input type="radio" class="btn-check" name="gender" id="gender-male">
                                        <label class="btn" for="gender-male">Male</label>
                                        <input type="radio" class="btn-check" name="gender" id="gender-female">
                                        <label class="btn" for="gender-female">Female</label>
