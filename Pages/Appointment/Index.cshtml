                url: "/Appointment?handler=UpsertPortalDependent",
                type: "POST",
                dataType: "json",
                contentType: "application/json",
                data: JSON.stringify(payload),
                success: function (res) {
                    $btn.prop("disabled", false).text("Save");
                    var ok = res && (res.success === true || res.Success === true);
                    var msg = (res && (res.message || res.Message)) || "";
                    function notifySuccess(text) {
                        if (typeof toastr !== "undefined") {
                            toastr.success(text || "Dependent saved.");
                        } else {
                            alert(text || "Dependent saved.");
                        }
                    }
                    function notifyError(text) {
                        if (typeof toastr !== "undefined") {
                            toastr.error(text || "Could not save dependent.");
                        } else {
                            alert(text || "Could not save dependent.");
                        }
                    }
                    function hideDependentModal() {
                        var mEl = document.getElementById("addDependentAppointmentModal");
                        if (!mEl || typeof bootstrap === "undefined") return;
                        var mi = bootstrap.Modal.getInstance(mEl);
                        if (!mi) mi = bootstrap.Modal.getOrCreateInstance(mEl);
                        mi.hide();
                        if (typeof window.cleanupAppointmentModalBackdrop === "function") {
                            window.cleanupAppointmentModalBackdrop();
                        }
                    }
                    if (ok) {
                        notifySuccess(msg || "Dependent saved.");
                        hideDependentModal();
                        try {
                            var newId = res.id != null ? res.id : res.Id;
                            var nid = newId != null && newId !== "" ? Number(newId) : 0;
                            if (!nid || isNaN(nid) || nid <= 0) {
                                nid = fallbackDependentProfileId != null ? Number(fallbackDependentProfileId) : 0;
                            }
                            if (nid > 0 && !isNaN(nid)) {
                                $("#PatientId").val(String(nid));
                                if (typeof appendPortalBookingSubjectAfterUpsert === "function") {
                                    appendPortalBookingSubjectAfterUpsert({ id: nid, success: true });
                                }
                            }
                        } catch (e) { /* dropdown update must not block UX */ }
                        setTimeout(function () {
                            if (typeof refreshPortalDependentsGrid === "function") {
                                refreshPortalDependentsGrid();
                            }
                        }, 400);
                    } else {
                        notifyError(msg || "Could not save dependent.");
                    }
                },
                error: function (xhr) {
                    $btn.prop("disabled", false).text("Save");
                    var errText = "Could not save dependent.";
                    try {
                        var j = typeof xhr.responseJSON === "object" && xhr.responseJSON !== null
                            ? xhr.responseJSON
                            : JSON.parse(xhr.responseText || "{}");
                        if (j && (j.message || j.Message)) errText = j.message || j.Message;
                    } catch (e) { /* ignore */ }
                    if (typeof toastr !== "undefined") toastr.error(errText);
                    else alert(errText);
                }
            });
        });

        $("#save-btn").click(function (e) {
            var $button = $(this);
            e.preventDefault();

            function resetBookButton() {
                $button.prop("disabled", false).text("Book");
            }

            $button.prop("disabled", true).text("Submitting...");

            try {
            var isValid = true;
            var portalBooking = window.__isPatientPortalBooking === true;
            var emailRegex = /^[\w\.-]+@@([\w\.-]+\.\w+)$/;

            function getPiReschedDate() {
                var el = document.getElementById("pi-resched");
                if (!el || !el.ej2_instances || !el.ej2_instances[0]) return null;
                var v = el.ej2_instances[0].value;
                if (v == null || v === "") return null;
                var d = v instanceof Date ? v : new Date(v);
                return isNaN(d.getTime()) ? null : d;
            }

            function getFormOfAppointmentText() {
                if (typeof ejsDropdownTextValue === "function") {
                    return (ejsDropdownTextValue("pi-formofappt") || "").trim();
                }
                return ($("#pi-formofappt").val() || "").trim();
            }

            function getPiDobDdMmYyyy() {
                var el = document.getElementById("pi-dob");
                if (el && el.ej2_instances && el.ej2_instances[0]) {
                    var v = el.ej2_instances[0].value;
                    if (!v) return "";
                    var d = v instanceof Date ? v : new Date(v);
                    if (isNaN(d.getTime())) return "";
                    var dd = String(d.getDate()).padStart(2, "0");
                    var mm = String(d.getMonth() + 1).padStart(2, "0");
                    return dd + "/" + mm + "/" + d.getFullYear();
                }
                return ($("#pi-dob").val() || "").trim();
            }

            function showError(inputId, message) {
                var $c = $("#" + inputId).closest(".col-md-6, .col-xl-4, .col-md-12, .col-12");
                if ($c.length) $c.first().find(".text-danger").first().text(message);
                else $("#" + inputId).closest("div").find(".text-danger").first().text(message);
            }

            function clearError(inputId) {
                var $c = $("#" + inputId).closest(".col-md-6, .col-xl-4, .col-md-12, .col-12");
                if ($c.length) $c.first().find(".text-danger").first().text("");
                else $("#" + inputId).closest("div").find(".text-danger").first().text("");
            }

            $("#pi-formofappt-msg, #AppointmentDateSpan, #pi-phoneno-msg, #pi-appointment-for-span, #pi-portal-display-name-span, #pi-portal-profile-msg").text("");
            $("#emailidspan, #dobspan, #Namespan, #agespan, #Genderspan").text("");

            if (portalBooking && typeof validatePortalSubjectWithFieldMessages === "function") {
                if (!validatePortalSubjectWithFieldMessages()) isValid = false;
            }

            var formTypeText = getFormOfAppointmentText();
            if (!formTypeText) {
                $("#pi-formofappt-msg").text("Type of appointment is required.");
                isValid = false;
            }

            if (!portalBooking) {
                var nm = ($("#pi-name").val() || "").trim();
                if (!nm) {
                    $("#Namespan").text("Name is required.");
                    isValid = false;
                }
                var ag = ($("#pi-age").val() || "").trim();
                if (!ag) {
                    $("#agespan").text("Age is required.");
                    isValid = false;
                } else {
                    var anAnon = parseInt(ag, 10);
                    if (isNaN(anAnon) || anAnon < 1 || anAnon > 99) {
                        $("#agespan").text("Enter a valid age (1–99).");
                        isValid = false;
                    }
                }
                if (!$("input[name='gender']:checked").length) {
                    $("#Genderspan").text("Gender is required.");
                    isValid = false;
                }
                var emAnon = ($("#pi-email").val() || "").trim();
                if (!emAnon) {
                    $("#emailidspan").text("Email is required.");
                    isValid = false;
                } else if (!emailRegex.test(emAnon)) {
                    $("#emailidspan").text("Invalid email address.");
                    isValid = false;
                }
            }

            var ageValue = ($("#pi-age").val() || "").trim();
            if (!portalBooking && ageValue !== "" && (isNaN(ageValue) || parseInt(ageValue, 10) < 0 || parseInt(ageValue, 10) > 99)) {
                showError("pi-age", "Invalid Age.");
                isValid = false;
            } else if (!portalBooking) {
                clearError("pi-age");
            }

            var selectedApptDate = getPiReschedDate();
            var currentDateTime = new Date();
            var maxDateTime = new Date();
            maxDateTime.setFullYear(maxDateTime.getFullYear() + 10);
            var startHour = 10;
            var endHour = 19;
            var manualPickerApptType = formTypeText === "Dr. Sejal Online Consultation"
                || formTypeText === "Appointment Request for Procedures";

            if (!selectedApptDate) {
                $("#AppointmentDateSpan").text("Appointment date and time is required.");
                isValid = false;
            } else {
                var enteredHour = selectedApptDate.getHours();
                var enteredMinutes = selectedApptDate.getMinutes();
                if (selectedApptDate < currentDateTime) {
                    $("#AppointmentDateSpan").text("Appointment cannot be in the past.");
                    isValid = false;
                } else if (selectedApptDate > maxDateTime) {
                    $("#AppointmentDateSpan").text("Appointment cannot be more than 10 years from today.");
                    isValid = false;
                } else if (manualPickerApptType && (selectedApptDate.getTime() - currentDateTime.getTime()) < 60 * 60 * 1000) {
                    $("#AppointmentDateSpan").text("Appointment must be at least one hour from now.");
                    isValid = false;
                } else if (selectedApptDate.getDay() === 0) {
                    $("#AppointmentDateSpan").text("Appointments cannot be scheduled on Sunday.");
                    isValid = false;
                } else if (enteredHour < startHour || (enteredHour === endHour && enteredMinutes > 0) || enteredHour > endHour) {
                    $("#AppointmentDateSpan").text("Appointment time should be between 10 AM and 7 PM.");
                    isValid = false;
                } else {
                    $("#AppointmentDateSpan").text("");
                }
            }

            if (portalBooking && $("#pi-email").length) {
                var portalProfileErrs = [];
                var email = ($("#pi-email").val() || "").trim();
                if (email !== "" && !emailRegex.test(email)) {
                    portalProfileErrs.push("Invalid email address. Correct the email in your profile or clear the field.");
                    isValid = false;
                } else {
                    clearError("pi-email");
                }
                if ($("#pi-dob").length) {
                    var dobStr = getPiDobDdMmYyyy();
                    if (dobStr && dobStr !== "") {
                        var dp = dobStr.split("/");
                        var dobDate = dp.length === 3
                            ? new Date(parseInt(dp[2], 10), parseInt(dp[1], 10) - 1, parseInt(dp[0], 10))
                            : null;
                        var currentDate = new Date();
                        var oneYearBack = new Date();
                        oneYearBack.setFullYear(currentDate.getFullYear());
                        var minDate = new Date();
                        minDate.setFullYear(currentDate.getFullYear() - 99);
                        if (!dobDate || isNaN(dobDate.getTime()) || dobDate > oneYearBack || dobDate < minDate) {
                            portalProfileErrs.push("Invalid date of birth on file. Update it in your profile.");
                            isValid = false;
                        } else {
                            clearError("pi-dob");
                        }
                    }
                }
                if ($("#pi-portal-profile-msg").length) {
                    $("#pi-portal-profile-msg").text(portalProfileErrs.join(" "));
                } else if (portalProfileErrs.length && typeof toastr !== "undefined") {
                    toastr.error(portalProfileErrs.join(" "));
                } else if (portalProfileErrs.length) {
                    alert(portalProfileErrs.join(" "));
                }
            }

            var phoneVal = ($("#pi-phoneno").val() || "").trim();
            if (phoneVal === "") {
                showError("pi-phoneno", "Phone number is required.");
                isValid = false;
            } else if (phoneVal.replace(/\D/g, "").length < 10) {
                showError("pi-phoneno", "Invalid mobile number.");
                isValid = false;
            } else {
                clearError("pi-phoneno");
            }

            if (!portalBooking && $("#save-btn").hasClass("a-disabled")) {
                showError("pi-phoneno", "Please verify your phone number with OTP.");
                isValid = false;
            }

            if (!isValid) {
                resetBookButton();
                return;
            }
            var genderMapping = {
                "gender-male": "Male",
                "gender-female": "Female",
                "gender-other": "Other"
            };

            var portalSubj = portalBooking && typeof getPortalSelectedSubjectRow === "function" ? getPortalSelectedSubjectRow() : null;

            var selectedGender = "";
            if (portalBooking && portalSubj && (portalSubj.gender || "").trim()) {
                selectedGender = String(portalSubj.gender).trim();
            } else if (typeof ejsDropdownTextValue === "function" && document.getElementById("pi-gender") && document.getElementById("pi-gender").ej2_instances && document.getElementById("pi-gender").ej2_instances[0]) {
                selectedGender = ejsDropdownTextValue("pi-gender");
            } else {
                var selectedGenderId = $("input[name='gender']:checked").attr("id");
                selectedGender = genderMapping[selectedGenderId] || "";
            }

            var relationVal = "";
            if (portalBooking && portalSubj && (portalSubj.relationName || "").trim()) {
                relationVal = String(portalSubj.relationName).trim();
            } else if (typeof getRelationNameFromRelationDropdown === "function" && document.getElementById("pi-relation") && document.getElementById("pi-relation").ej2_instances && document.getElementById("pi-relation").ej2_instances[0]) {
                relationVal = getRelationNameFromRelationDropdown();
            } else {
                relationVal = ($("#pi-relation").val() || "").trim();
            }
            function formatDateToMMDDYYYY(dateString) {
                if (!dateString) return "";
                var parts = dateString.split("/");
                if (parts.length === 3) {
                    return parts[1] + "/" + parts[0] + "/" + parts[2];
                }
                return dateString;
            }

            function formatLocalDateTimeForApi(d) {
                if (!d || isNaN(d.getTime())) return "";
                var y = d.getFullYear();
                var m = String(d.getMonth() + 1).padStart(2, "0");
                var day = String(d.getDate()).padStart(2, "0");
                var h = String(d.getHours()).padStart(2, "0");
                var mi = String(d.getMinutes()).padStart(2, "0");
                var s = String(d.getSeconds()).padStart(2, "0");
                return y + "-" + m + "-" + day + "T" + h + ":" + mi + ":" + s;
            }

            var dobValue = getPiDobDdMmYyyy();
            var formattedDob = formatDateToMMDDYYYY(dobValue);
            var appointmentStartForApi = formatLocalDateTimeForApi(selectedApptDate);

            var apptForEl = document.getElementById("pi-appointment-for");
            var apptForRawValue = null;
            var apptForItemDataSnap = null;
            if (apptForEl && apptForEl.ej2_instances && apptForEl.ej2_instances[0]) {
                var afInst = apptForEl.ej2_instances[0];
                apptForRawValue = afInst.value;
                var idRow = afInst.itemData;
                if (idRow && typeof idRow === "object") {
                    apptForItemDataSnap = {
                        profileId: idRow.profileId,
                        ProfileId: idRow.ProfileId,
                        displayLabel: idRow.displayLabel,
                        DisplayLabel: idRow.DisplayLabel,
                        name: idRow.name,
                        Name: idRow.Name
                    };
                }
            }

            var resolvedPatientId = null;
            if (portalBooking && typeof getPiAppointmentForItemProfileId === "function") {
                var idItem = getPiAppointmentForItemProfileId();
                if (idItem != null && idItem > 0) resolvedPatientId = idItem;
            }
            if (resolvedPatientId == null && portalBooking && portalSubj) {
                var spid = portalSubj.profileId != null ? portalSubj.profileId : portalSubj.ProfileId;
                if (spid != null && spid !== "") {
                    var nSp = Number(spid);
                    if (!isNaN(nSp) && nSp > 0) resolvedPatientId = nSp;
                }
            }
            if (resolvedPatientId == null && typeof ejsDropdownNumericValue === "function") {
                var ddlPid = ejsDropdownNumericValue("pi-appointment-for");
                if (ddlPid != null && ddlPid > 0) resolvedPatientId = ddlPid;
            }
            if (resolvedPatientId == null) {
                var pid = $("#PatientId").val();
                var parsedPid = pid ? parseInt(pid, 10) : null;
                if (parsedPid && !isNaN(parsedPid) && parsedPid > 0) resolvedPatientId = parsedPid;
            }
            if (resolvedPatientId == null && window.__appointmentPatientId != null) {
                var ap = Number(window.__appointmentPatientId);
                if (!isNaN(ap) && ap > 0) resolvedPatientId = ap;
            }
            if (portalBooking && typeof applyPortalBookingSubjectByProfileId === "function" && resolvedPatientId != null) {
                applyPortalBookingSubjectByProfileId(resolvedPatientId);
            }

            if (typeof console !== "undefined" && console.info) {
                console.info("[Appointment Book] pi-appointment-for inst.value:", apptForRawValue);
                console.info("[Appointment Book] pi-appointment-for itemData (snapshot):", apptForItemDataSnap);
                console.info("[Appointment Book] getPiAppointmentForItemProfileId():", typeof getPiAppointmentForItemProfileId === "function" ? getPiAppointmentForItemProfileId() : "(n/a)");
                console.info("[Appointment Book] portalSubj:", portalSubj);
                console.info("[Appointment Book] ejsDropdownNumericValue(pi-appointment-for):", typeof ejsDropdownNumericValue === "function" ? ejsDropdownNumericValue("pi-appointment-for") : "(n/a)");
                console.info("[Appointment Book] #PatientId:", $("#PatientId").val());
                console.info("[Appointment Book] __appointmentPatientId:", window.__appointmentPatientId, "__portalParentProfileId:", window.__portalParentProfileId);
                console.info("[Appointment Book] resolvedPatientId (final for API):", resolvedPatientId);
            }

            var resolvedNameForBooking = "";
            if (portalBooking && portalSubj) {
                if (window.__requirePortalDisplayName === true && typeof isPortalAppointmentForSelf === "function" && isPortalAppointmentForSelf()) {
                    resolvedNameForBooking = ($("#pi-portal-display-name").val() || "").trim();
                } else {
                    resolvedNameForBooking = (portalSubj.name || "").trim();
                }
            } else {
                resolvedNameForBooking = ($("#pi-name").val() || "").trim();
            }

            var formData = {
                Name: resolvedNameForBooking,
                Email: portalBooking ? $("#pi-email").val() : ($("#pi-email").val() || ""),
                FormofAppointment: formTypeText,
                Mobile: $("#pi-phoneno").val(),
                Comment: $("#pi-notes").val(),
                Relation: portalBooking ? relationVal : ($("#pi-relation").val() || "").trim(),
                AppointmentStartTime: appointmentStartForApi,
                Age: portalBooking && portalSubj && portalSubj.age != null && portalSubj.age !== "" ? String(portalSubj.age) : $("#pi-age").val(),
                Dob: formattedDob,
                Gender: selectedGender,
                PatientId: resolvedPatientId
            };

            if (typeof console !== "undefined" && console.info) {
                console.info("[Appointment Book] formData.PatientId:", formData.PatientId);
                console.info("[Appointment Book] request JSON snippet:", JSON.stringify({ PatientId: formData.PatientId, Name: formData.Name }));
            }

            $.ajax({
                url: "/Appointment/Index?handler=Pireschedule",
                type: "POST",
                dataType: "json",
                contentType: "application/json",
                data: JSON.stringify(formData),
                success: function (response) {
                    try {
                        var ok = response && (response.isSuccess === true || response.IsSuccess === true);
                        if (!ok) {
                            var ec = response && (response.errorCode || response.ErrorCode);
                            var err = (response && w.portalAppointmentMessageFromJsonResult(response)) || "Could not book this appointment.";
                            if (ec === "APPOINTMENT_MINIMUM_LEAD_TIME") {
                                if (typeof toastr !== "undefined") toastr.warning(err);
                                else alert(err);
                                $("#AppointmentDateSpan").text(err).show();
                            } else if (ec === "APPOINTMENT_TIME_REQUIRED") {
                                $("#AppointmentDateSpan").text(err).show();
                                if (typeof toastr !== "undefined") toastr.info(err);
                                else alert(err);
                            } else if (ec === "PATIENT_PORTAL_RESCHEDULE_LIMIT_REACHED") {
                                $("#AppointmentDateSpan").text(err).show();
                                if (typeof toastr !== "undefined") toastr.warning(err);
                                else alert(err);
                            } else {
                                $("#AppointmentDateSpan").text(err).show();
                                if (typeof toastr !== "undefined") toastr.error(err);
                                else alert(err);
                            }
                            if ($("#pi-portal-profile-msg").length) $("#pi-portal-profile-msg").text("");
                            resetBookButton();
                            return;
                        }
                        resetBookButton();
                        var thanksUrl = typeof window.__postAppointmentRedirectUrl === "string" && window.__postAppointmentRedirectUrl.length
                            ? window.__postAppointmentRedirectUrl
                            : "https://www.inurskn.in/";
                        var thanksMsgHtml = "Thank You. Your appointment request has been sent to clinic.<br><br>Please expect a wait time of about 30 minutes from your scheduled time of appointment.";
                        var thanksMsgPlain = "Thank You. Your appointment request has been sent to clinic.\n\nPlease expect a wait time of about 30 minutes from your scheduled time of appointment.";
                        if (typeof Swal !== "undefined" && Swal.fire) {
                            Swal.fire({
                                icon: "success",
                                html: thanksMsgHtml,
                                confirmButtonText: "Thanks",
                                confirmButtonColor: "#137A5D",
                                customClass: {
                                    popup: "rounded-3",
                                    title: "text-success"
                                }
                            }).then(function (result) {
                                if (result.isConfirmed) {
                                    window.location.href = thanksUrl;
                                }
                            });
                        } else {
                            alert(thanksMsgPlain);
                            window.location.href = thanksUrl;
                        }
                    } catch (ex) {
                        resetBookButton();
                        if (typeof console !== "undefined" && console.error) console.error(ex);
                        alert("Something went wrong after booking. Please check your appointments or try again.");
                    }
                },
                error: function (xhr) {
                    portalAppointmentHandleHttpError(xhr, {
                        $span: $("#AppointmentDateSpan"),
                        onDone: resetBookButton
                    });
                }
            });
            } catch (err) {
                resetBookButton();
                if (typeof console !== "undefined" && console.error) console.error(err);
            }
        });
        $(document).ready(function () {
            // Check if success message flag is set in localStorage
            if (localStorage.getItem("showPatientSuccessMessage") === "true") {
                toastr.success("Patient details saved successfully!"); // Show success message
                localStorage.removeItem("showPatientSuccessMessage"); // Remove flag after showing message
            }
        });
         $("#confirmYes").click(function () {
        window.location.href = "https://www.inurskn.in/"; // Redirect to /account
    });
    });
</script>
<script>
document.addEventListener("click", function (event) {
    var btn = event.target && event.target.closest && event.target.closest("#cancel-btn");
    if (!btn) return;
    event.preventDefault();
    if (window.__isLoggedInForAppointmentCancel === true) {
        var u = typeof window.__appointmentCancelPatientUrl === "string" ? window.__appointmentCancelPatientUrl.trim() : "";
        if (u.length) {
            window.location.href = u;
            return;
        }
    }
    window.location.reload();
}, true);

</script>

