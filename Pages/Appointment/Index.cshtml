            var raw = '';
            if (args && args.value != null && args.value !== '') raw = String(args.value);
            else if (ddlInstForVal && ddlInstForVal.value != null && ddlInstForVal.value !== '') raw = String(ddlInstForVal.value);
            var t = raw.trim();
            var prevType = __lastAppointmentType;
            var prevTrim = (prevType || '').trim();
            if (isAppointmentTypeSelected(prevTrim) && prevTrim !== t) {
                dateTimePicker.value = null;
            }

            if (!isAppointmentTypeSelected(t)) {
                if (wrap) {
                    wrap.classList.remove('scheduler-only-pick');
                    wrap.classList.add('appt-datetime-disabled');
                }
                dateTimePicker.readonly = true;
                if (typeof dateTimePicker.openOnFocus === 'boolean') dateTimePicker.openOnFocus = false;
                var sotNone = new Date();
                sotNone.setHours(0, 0, 0, 0);
                dateTimePicker.min = sotNone;
                dateTimePicker.value = null;
                if ($calBtn && $calBtn.length) {
                    $calBtn.removeClass('d-none').prop('disabled', true).attr('aria-disabled', 'true');
                }
                dateTimePicker.dataBind();
                __lastAppointmentType = t;
                return;
            }

            if (wrap) wrap.classList.remove('appt-datetime-disabled');

            if (wrap) {
                if (t === APPT_IN_PERSON) wrap.classList.add('scheduler-only-pick');
                else wrap.classList.remove('scheduler-only-pick');
            }

            if ($calBtn && $calBtn.length) {
                $calBtn.prop('disabled', false).removeAttr('aria-disabled');
            }

            if (t === APPT_IN_PERSON) {
                dateTimePicker.readonly = true;
                if (typeof dateTimePicker.openOnFocus === 'boolean') dateTimePicker.openOnFocus = false;
                var startOfToday = new Date();
                startOfToday.setHours(0, 0, 0, 0);
                dateTimePicker.min = startOfToday;
                if ($calBtn && $calBtn.length) $calBtn.removeClass('d-none');
            } else if (t === APPT_ONLINE || t === APPT_PROCEDURES) {
                dateTimePicker.readonly = false;
                /* Default false: open via date/time icons. true can block icon-open behavior in some EJ2 builds. */
                if (typeof dateTimePicker.openOnFocus === 'boolean') dateTimePicker.openOnFocus = false;
                var minManual = computeManualMinDateTime();
                dateTimePicker.min = minManual;
                if (dateTimePicker.value && dateTimePicker.value < minManual) {
                    dateTimePicker.value = null;
                }
                if (!dateTimePicker.value && selectedDateTime != null
                    && !isNaN(selectedDateTime.getTime()) && selectedDateTime >= minManual
                    && !isAppointmentTypeSelected(prevTrim)) {
                    dateTimePicker.value = selectedDateTime;
                }
                if ($calBtn && $calBtn.length) $calBtn.addClass('d-none');
            }

            dateTimePicker.dataBind();
            __lastAppointmentType = t;
        };
    })();

