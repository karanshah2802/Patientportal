<style>
    /* Disable <a> buttons */
    .a-disabled {
        pointer-events: none; /* Prevent click */
        opacity: 0.5; /* Make it look disabled */
    }
</style>

<script>
    if (window.__isPatientPortalBooking !== true) {
        window.__appointmentPatientId = null;
    }

    function applyProfileFromOtp(profile) {
        if (!profile || !profile.id) return;
        window.__appointmentPatientId = profile.id;
        $('#PatientId').val(profile.id);

        var name = profile.name && String(profile.name).trim();
        if (name) {
            $('#pi-name').val(name).prop('readonly', true).addClass('bg-light');
        }
        var email = profile.email && String(profile.email).trim();
        if (email) {
            $('#pi-email').val(email).prop('readonly', true).addClass('bg-light');
        }
        if (profile.mobile) {
            var digits = String(profile.mobile).replace(/\D/g, '');
            if (digits.length >= 10) {
                $('#pi-phoneno').val(digits.slice(-10));
            }
        }
        var gender = profile.gender && String(profile.gender).trim();
        if (gender) {
            var g = gender.toLowerCase();
            if (g === 'male') {
                $('#gender-male').prop('checked', true);
            } else if (g === 'female') {
                $('#gender-female').prop('checked', true);
            } else {
                $('#gender-other').prop('checked', true);
            }
            $('input[name="gender"]').prop('disabled', true);
        }

        var dobInst = document.getElementById('pi-dob') && document.getElementById('pi-dob').ej2_instances && document.getElementById('pi-dob').ej2_instances[0];
        var hasDob = profile.dob != null && profile.dob !== '';
        if (hasDob && dobInst) {
            var d = new Date(profile.dob);
            if (!isNaN(d.getTime())) {
                dobInst.value = d;
                dobInst.readonly = true;
                var today = new Date();
                var age = today.getFullYear() - d.getFullYear();
                var m = today.getMonth() - d.getMonth();
                if (m < 0 || (m === 0 && today.getDate() < d.getDate())) {
                    age--;
                }
                $('#pi-age').val(age).prop('readonly', true).addClass('bg-light');
            }
        } else if (profile.age != null && profile.age !== '' && !isNaN(parseInt(profile.age, 10))) {
            $('#pi-age').val(parseInt(profile.age, 10)).prop('readonly', true).addClass('bg-light');
        }
    }

    $(document).ready(function () {
        const $phoneInput = $('#pi-phoneno');
        const $verifyBtn = $('#verify-btn');
        const $otpModal = new bootstrap.Modal(document.getElementById('otpModal'));
        const $otpInput = $('#otp-input');
        const $otpSubmitBtn = $('#otp-submit-btn');
        const $saveBtn = $('#save-btn');

        if (window.__isPatientPortalBooking === true) {
            $saveBtn.removeClass('a-disabled');
            $verifyBtn.addClass('d-none');
        } else {
            $saveBtn.addClass('a-disabled');
            $verifyBtn.addClass('d-none');
        }

        $('#open-slot-calendar-btn').on('click', function () {
            var ddlEl = document.getElementById('pi-formofappt');
            var ddl = ddlEl && ddlEl.ej2_instances && ddlEl.ej2_instances[0];
            var t = ddl && ddl.value != null && ddl.value !== '' ? String(ddl.value) : '';
            if (!t) {
                return;
            }
            if (t === 'Dr. Sejal Online Consultation' || t === 'Appointment Request for Procedures') {
                if (typeof toastr !== 'undefined') {
                    toastr.info('For this appointment type, use the date and time field below.');
                } else {
                    alert('For this appointment type, use the date and time field below.');
                }
                return;
            }
            var modalEl = document.getElementById('appointmentSlotModal');
            if (modalEl && typeof bootstrap !== 'undefined') {
                var modal = bootstrap.Modal.getOrCreateInstance(modalEl);
                modal.show();
            }
        });

        $phoneInput.on('input', function () {
            if (window.__isPatientPortalBooking === true) return;
            // Hide Verify button on any input change
            $verifyBtn.addClass('d-none');

            // Disable Save whenever phone input changes
            $saveBtn.addClass('a-disabled');

            // Show Verify button only if 10-digit number
            const val = $(this).val();
            if (val.length === 10 && /^\d{10}$/.test(val)) {
                $verifyBtn.removeClass('d-none');
                $verifyBtn.removeClass('a-disabled'); // enable Save
            }
        });

        $verifyBtn.on('click', function () {
            const mobile = $phoneInput.val();
            $.ajax({
                url: '/Appointment?handler=SendOTP',
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ Mobile: mobile }),
                success: function (res) {
                    if (res.success) {
                        $otpInput.val('');
                        $('#otp-msg').text('');
                        $otpSubmitBtn.prop('disabled', true);
                        $verifyBtn.addClass('a-disabled'); // enable Save
                        $otpModal.show();
                    } else {
                        $('#pi-phoneno-msg').text(res.message);
                    }
                }
            });
        });

        $otpInput.on('input', function () {
            const val = $(this).val();
            $otpSubmitBtn.prop('disabled', !(val.length >= 4 && val.length <= 6));
        });

        $otpSubmitBtn.on('click', function () {
            const mobile = $phoneInput.val();
            const otp = $otpInput.val();
            $.ajax({
                url: '/Appointment?handler=VerifyOTP',
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ Mobile: mobile, OTP: otp }),
                success: function (res) {
                    if (res.success) {
                        $('#otp-msg').text(res.message);
                        $otpModal.hide();
                        if (res.reloadForPortalBooking) {
                            try {
                                var ft = typeof ejsDropdownTextValue === "function" ? ejsDropdownTextValue("pi-formofappt") : "";
                                var dtpEl = document.getElementById("pi-resched");
                                var iso = null;
                                if (dtpEl && dtpEl.ej2_instances && dtpEl.ej2_instances[0] && dtpEl.ej2_instances[0].value) {
                                    var d = dtpEl.ej2_instances[0].value;
                                    if (d instanceof Date && !isNaN(d.getTime())) {
                                        iso = d.toISOString();
                                    }
                                }
                                sessionStorage.setItem("pp_appt_restore_after_otp", JSON.stringify({
                                    formType: (ft || "").trim(),
                                    dateTimeIso: iso
                                }));
                            } catch (persistEx) { /* still reload */ }
                            window.location.reload();
                            return;
                        }
                        $saveBtn.removeClass('a-disabled'); // enable Save
                        $verifyBtn.addClass('a-disabled'); // enable Save
                        $phoneInput.prop('readonly', true).addClass('bg-light');
                        if (res.hasExistingProfile && res.profile) {
                            applyProfileFromOtp(res.profile);
                        } else {
                            window.__appointmentPatientId = null;
                            $('#PatientId').val('');
                        }
                        toastr.success("OTP Verifyed successfully!"); // Show success message
                    } else {
                        $('#otp-msg').text(res.message);


                        $saveBtn.addClass('a-disabled'); // keep disabled
                    }
                }
            });
        });
    });
</script>

<script>
    function onPortalDependentsGridCreated(args) {
        var u = typeof window.__portalDependentsDmUrl === "string" ? window.__portalDependentsDmUrl : "";
        if (!u || u.indexOf("profileId=0") >= 0) return;
        try {
            var grid = (this && this.dataSource) ? this : (args && args.dataSource ? args : null);
            if (grid && grid.dataSource && typeof grid.dataSource.url === "string")
                grid.dataSource.url = u;
        } catch (e) { /* non-fatal */ }
    }
    function openPortalDependentEditFromRow(d) {
        if (!d) return;
        var id = d.id != null ? d.id : d.Id;
        var em = d.emails != null ? d.emails : d.Emails;
        if (id != null && id !== '') {
            $('#PatientId').val(String(id));
            var af = document.getElementById("pi-appointment-for");
            if (af && af.ej2_instances && af.ej2_instances[0]) {
                af.ej2_instances[0].value = Number(id);
                af.ej2_instances[0].dataBind();
            }
        }
        var $em = $('#pi-email');
        if ($em.length && em) {
