    <script>
        function ejsDropdownTextValue(elementId) {
            var el = document.getElementById(elementId);
            if (!el || !el.ej2_instances || !el.ej2_instances[0]) return "";
            var inst = el.ej2_instances[0];
            var v = inst.value;
            if (v != null && v !== "") return String(v).trim();
            var tx = inst.text;
            if (tx != null && tx !== "") {
                var ph = inst.placeholder;
                if (!ph || String(tx) !== String(ph)) return String(tx).trim();
            }
            return "";
        }
        function ejsDropdownNumericValue(elementId) {
            var el = document.getElementById(elementId);
            if (!el || !el.ej2_instances || !el.ej2_instances[0]) return null;
            var inst = el.ej2_instances[0];
            var v = inst.value;
            if (v != null && v !== "") {
                var n = Number(v);
                if (!isNaN(n)) return n;
            }
            var item = inst.itemData;
            if (item && item.Id != null && item.Id !== "") {
                var n2 = Number(item.Id);
                if (!isNaN(n2)) return n2;
            }
            return null;
        }
        function setEjsDropdownValue(elementId, value) {
            var el = document.getElementById(elementId);
            if (!el || !el.ej2_instances || !el.ej2_instances[0]) return;
            el.ej2_instances[0].value = value !== undefined && value !== null && value !== "" ? value : null;
            el.ej2_instances[0].dataBind();
        }
        function setRelationDropdownByName(nameStr) {
            var el = document.getElementById("pi-relation");
            if (!el || !el.ej2_instances || !el.ej2_instances[0] || !nameStr) return;
            var inst = el.ej2_instances[0];
            var ds = inst.dataSource;
            if (!ds || !ds.length) return;
            var target = String(nameStr).trim().toLowerCase();
            for (var i = 0; i < ds.length; i++) {
                var row = ds[i];
                var nm = row.Name != null ? String(row.Name).trim().toLowerCase() : "";
                if (nm === target) {
                    inst.value = row.Id;
                    inst.dataBind();
                    return;
                }
            }
        }
        function setDepModalRelationByName(nameStr) {
            var el = document.getElementById("dep-modal-relation");
            if (!el || !el.ej2_instances || !el.ej2_instances[0] || !nameStr) return;
            var inst = el.ej2_instances[0];
            var ds = inst.dataSource;
            if (!ds || !ds.length) return;
            var target = String(nameStr).trim().toLowerCase();
            for (var i = 0; i < ds.length; i++) {
                var row = ds[i];
                var nm = row.Name != null ? String(row.Name).trim().toLowerCase() : "";
                if (nm === target) {
                    inst.value = row.Id;
                    inst.dataBind();
                    return;
                }
            }
        }
        function getRelationNameFromRelationDropdown() {
            var el = document.getElementById("pi-relation");
            if (!el || !el.ej2_instances || !el.ej2_instances[0]) return "";
            var inst = el.ej2_instances[0];
            var v = inst.value;
            if (v == null || v === "") return "";
            var ds = inst.dataSource;
            if (!ds || !ds.length) return "";
            for (var i = 0; i < ds.length; i++) {
                var row = ds[i];
                if (Number(row.Id) === Number(v)) return row.Name != null ? String(row.Name) : "";
            }
            return "";
        }
        function getDepModalRelationName() {
            var el = document.getElementById("dep-modal-relation");
            if (!el || !el.ej2_instances || !el.ej2_instances[0]) return "";
            var inst = el.ej2_instances[0];
            var v = inst.value;
            if (v == null || v === "") return "";
            var ds = inst.dataSource;
            if (!ds || !ds.length) return "";
            for (var i = 0; i < ds.length; i++) {
                var row = ds[i];
                if (Number(row.Id) === Number(v)) return row.Name != null ? String(row.Name) : "";
            }
            return "";
        }
        function getPortalSelectedSubjectRow() {
            var af = document.getElementById("pi-appointment-for");
            if (!af || !af.ej2_instances || !af.ej2_instances[0]) return null;
            var inst = af.ej2_instances[0];
            var v = inst.value;
            if (v == null || v === "") return null;
            var id = Number(v);
            if (isNaN(id) || id <= 0) return null;
            function rowMatchesProfileId(row) {
                if (!row) return false;
                var pid = row.profileId != null ? row.profileId : row.ProfileId;
                return Number(pid) === id;
            }
            var list = window.__portalBookingSubjects || [];
            for (var i = 0; i < list.length; i++) {
                if (rowMatchesProfileId(list[i])) return list[i];
            }
            var ds = inst.dataSource;
            if (ds && ds.length) {
                for (var j = 0; j < ds.length; j++) {
                    if (rowMatchesProfileId(ds[j])) return ds[j];
                }
            }
            return null;
        }
        /** ProfileId from the Syncfusion "Appointment for" dropdown selected row (itemData); most reliable for submit. */
        function getPiAppointmentForItemProfileId() {
            var el = document.getElementById("pi-appointment-for");
            if (!el || !el.ej2_instances || !el.ej2_instances[0]) return null;
            var inst = el.ej2_instances[0];
            var row = inst.itemData;
            if (!row || typeof row !== "object") return null;
            var p = row.profileId != null ? row.profileId : row.ProfileId;
            if (p == null || p === "") return null;
            if (typeof p === "number" && !isNaN(p) && p > 0) return p;
            var n = parseInt(String(p).trim(), 10);
            return !isNaN(n) && n > 0 ? n : null;
        }
        function clearDependentModalValidationMessages() {
            $("#dep-modal-namespan").text("");
            $("#dep-modal-agespan").text("");
            $("#dep-modal-genderspan").text("");
            $("#dep-modal-relationspan").text("");
        }
        function clearDependentModalForAdd() {
            $("#dep-modal-editing-profile-id").val("");
            $("#dep-modal-name").val("");
            $("#dep-modal-age").val("");
            clearDependentModalValidationMessages();
            setEjsDropdownValue("dep-modal-gender", null);
            setEjsDropdownValue("dep-modal-relation", null);
            var t = document.getElementById("addDependentAppointmentModalLabel");
            if (t) t.textContent = "Add Dependent Patient";
        }
        function fillDependentModalFromGridRow(d) {
            clearDependentModalValidationMessages();
            var id = d.id != null ? d.id : d.Id;
            $("#dep-modal-editing-profile-id").val(id != null && id !== "" ? String(id) : "");
            var nm = d.name != null ? d.name : d.Name;
            var ag = d.age != null ? d.age : d.Age;
            var gen = d.gender != null ? d.gender : d.Gender;
            $("#dep-modal-name").val(nm != null ? String(nm) : "");
            $("#dep-modal-age").val(ag != null && ag !== "" ? String(ag) : "");
            var gNorm = gen != null ? String(gen).trim() : "";
            if (gNorm) {
                var gl = gNorm.toLowerCase();
                if (gl === "female") setEjsDropdownValue("dep-modal-gender", "Female");
                else if (gl === "male") setEjsDropdownValue("dep-modal-gender", "Male");
                else setEjsDropdownValue("dep-modal-gender", "Other");
            } else setEjsDropdownValue("dep-modal-gender", null);
            var relPick = d.patientRelationshipName != null ? d.patientRelationshipName : (d.PatientRelationshipName != null ? d.PatientRelationshipName : "");
            if (relPick) setDepModalRelationByName(String(relPick).trim());
            else setEjsDropdownValue("dep-modal-relation", null);
            var t = document.getElementById("addDependentAppointmentModalLabel");
            if (t) t.textContent = "Edit Dependent Patient";
        }
        function isPortalAppointmentForSelf() {
            var parentId = window.__portalParentProfileId != null ? parseInt(window.__portalParentProfileId, 10) : 0;
            var af = document.getElementById("pi-appointment-for");
            if (!af || !af.ej2_instances || !af.ej2_instances[0]) {
                var pv = parseInt($("#PatientId").val(), 10);
                return parentId > 0 && pv === parentId;
            }
            var v = af.ej2_instances[0].value;
            var sid = v != null && v !== "" ? parseInt(v, 10) : 0;
            return parentId > 0 && sid === parentId;
        }
        function onPortalAppointmentSubjectChange(args) {
            if (!args || args.value == null || args.value === "") return;
            applyPortalBookingSubjectByProfileId(args.value);
        }
        function applyPortalBookingSubjectByProfileId(profileId) {
            var list = window.__portalBookingSubjects;
            if (!list || !list.length) return;
            var id = Number(profileId);
            if (isNaN(id) || id <= 0) return;
            var row = null;
            for (var i = 0; i < list.length; i++) {
                if (Number(list[i].profileId) === id) {
                    row = list[i];
                    break;
                }
            }
            if (!row) return;
            $("#PatientId").val(String(row.profileId));
        }
        function appendPortalBookingSubjectAfterUpsert(res) {
            var id = res && res.id != null ? Number(res.id) : 0;
            if (!id || isNaN(id)) return;
            var list = window.__portalBookingSubjects || (window.__portalBookingSubjects = []);
            var name = (jQuery("#dep-modal-name").val() || "").trim();
            var age = parseInt((jQuery("#dep-modal-age").val() || "").trim(), 10);
            var gender = typeof ejsDropdownTextValue === "function" ? ejsDropdownTextValue("dep-modal-gender") : "";
            var relName = typeof getDepModalRelationName === "function" ? getDepModalRelationName() : "";
            var label = name || ("Dependent #" + id);
            var row = {
                profileId: id,
                displayLabel: label,
                name: name,
                age: isNaN(age) ? null : age,
                gender: gender || null,
                relationName: relName || null,
                isSelf: false
            };
            var dupIdx = list.findIndex(function (x) { return Number(x.profileId) === id; });
            if (dupIdx >= 0) list[dupIdx] = row;
            else list.push(row);
            var el = document.getElementById("pi-appointment-for");
            if (el && el.ej2_instances && el.ej2_instances[0]) {
                var ddl = el.ej2_instances[0];
                ddl.dataSource = list.slice();
                ddl.dataBind();
                ddl.value = id;
                ddl.dataBind();
            }
            jQuery("#PatientId").val(String(id));
        }
        function validateDependentModalFields() {
            clearDependentModalValidationMessages();
            var ok = true;
            var name = ($("#dep-modal-name").val() || "").trim();
            if (!name) {
                $("#dep-modal-namespan").text("Name is required.");
                ok = false;
            }
            var ageV = ($("#dep-modal-age").val() || "").trim();
            if (!ageV) {
                $("#dep-modal-agespan").text("Age is required.");
                ok = false;
            } else {
                var an = parseInt(ageV, 10);
                if (isNaN(an) || an < 1 || an > 99) {
                    $("#dep-modal-agespan").text("Enter a valid age (1–99).");
                    ok = false;
                }
            }
            var g = ejsDropdownTextValue("dep-modal-gender");
            if (!g) {
                $("#dep-modal-genderspan").text("Gender is required.");
                ok = false;
            }
            var relId = ejsDropdownNumericValue("dep-modal-relation");
            if (relId == null || relId <= 0) {
                var relByName = typeof getDepModalRelationName === "function" ? getDepModalRelationName() : "";
                if (!(relByName && String(relByName).trim())) {
                    $("#dep-modal-relationspan").text("Relation is required.");
                    ok = false;
                }
            }
            return ok;
        }
        function validatePortalAppointmentSubjectIdentity() {
            if (window.__isPatientPortalBooking !== true) return true;
            var row = getPortalSelectedSubjectRow();
            if (!row) return false;
            var forSelf = isPortalAppointmentForSelf();
            if (!(row.name || "").trim() && !forSelf) return false;
            if (!forSelf) {
                if (row.age == null || row.age === "" || isNaN(parseInt(row.age, 10))) return false;
                var an = parseInt(row.age, 10);
                if (an < 1 || an > 99) return false;
                if (!(row.gender || "").trim()) return false;
            }
            if (forSelf) return true;
            return !!(row.relationName || "").trim();
        }
        /** Inline errors on #pi-appointment-for-span; returns whether portal subject is complete. */
        function validatePortalSubjectWithFieldMessages() {
            $("#pi-appointment-for-span").text("");
            if (window.__isPatientPortalBooking !== true) return true;
            var afe = document.getElementById("pi-appointment-for");
            if (!afe || !afe.ej2_instances || !afe.ej2_instances[0]) return true;
            var row = getPortalSelectedSubjectRow();
            if (!row) {
                $("#pi-appointment-for-span").text("Please select who this appointment is for.");
                return false;
            }
            var forSelf = isPortalAppointmentForSelf();
            if (!(row.name || "").trim() && !forSelf) {
                $("#pi-appointment-for-span").text("Name is required. Add or edit dependent details.");
                return false;
            }
            if (!forSelf) {
                if (row.age == null || row.age === "" || isNaN(parseInt(row.age, 10))) {
                    $("#pi-appointment-for-span").text("Age is required for the selected dependent.");
                    return false;
                }
                var an = parseInt(row.age, 10);
                if (an < 1 || an > 99) {
                    $("#pi-appointment-for-span").text("Enter a valid age (1–99) for the selected dependent.");
                    return false;
                }
                if (!(row.gender || "").trim()) {
                    $("#pi-appointment-for-span").text("Gender is required for the selected dependent.");
                    return false;
                }
            }
            if (!forSelf && !(row.relationName || "").trim()) {
                $("#pi-appointment-for-span").text("Relation is required for dependents. Edit dependent to set relation.");
                return false;
            }
            if (forSelf && window.__requirePortalDisplayName === true) {
                var dn = ($("#pi-portal-display-name").val() || "").trim();
                if (!dn) {
                    $("#pi-portal-display-name-span").text("Patient name is required.");
                    return false;
                }
                $("#pi-portal-display-name-span").text("");
            }
            return true;
        }
    </script>

    <div class="modal fade" id="appointmentSlotModal" tabindex="-1" aria-labelledby="appointmentSlotModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-fullscreen d-flex flex-column m-0">
            <div class="modal-content d-flex flex-column flex-grow-1 rounded-0 border-0">
                <div class="modal-header border-bottom py-2 py-md-3">
                    <h5 class="modal-title" id="appointmentSlotModalLabel">Pick a date and time</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body d-flex flex-column flex-grow-1 p-0 overflow-hidden">
                    <div class="appointment-schedule-modal-wrap control-section flex-grow-1 portal-scheduler-loader-wrap">
                        <div class="portal-scheduler-loader" id="appointmentSlotModalScheduleLoader" role="status" aria-live="polite" aria-busy="false">
                            <div class="portal-sched-spinner" aria-hidden="true"></div>
                            <span class="portal-scheduler-loader-text">Loading schedule…</span>
                        </div>
                        <div class="schedule-wrapper-modal">
                            <ejs-schedule id="appointmentSlotSchedule"
                                          width="100%" height="100%"
                                          selectedDate="DateTime.Today"
                                          startHour="10:00" endHour="19:15"
                                          allowDragAndDrop="false" allowResizing="false"
                                          workDays="new int[] {1, 2, 3, 4, 5, 6}"
                                          cellClick="onAppointmentSlotCellClick">
                                <e-schedule-views>
