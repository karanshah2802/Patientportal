    <script id="appointmentBlockTemplate" type="text/x-template">
        <div class="blocked-slot" style="background-color:#7AB6E0;color:#fff;text-align:center;font-weight:600;padding:5px 6px;border-radius:4px;box-sizing:border-box;min-height:100%;width:100%;line-height:1.25;">Not available</div>
    </script>

    @* Same anchor-date behaviour as Patient when opening the slot modal from a reschedule link. *@
    <script>
        document.addEventListener("click", function (e) {
            var target = e.target.closest(".app-resched");
            if (target && target.dataset.starttime) {
                var originalDate = new Date(target.dataset.starttime);
                var today = new Date();
                today.setHours(0, 0, 0, 0);
                var appointmentDate = new Date(originalDate);
                appointmentDate.setHours(0, 0, 0, 0);
                if (appointmentDate >= today) {
                    originalDate.setDate(originalDate.getDate() + 7);
                    window.__patientRescheduleSchedulerAnchorDate = originalDate;
                } else {
                    window.__patientRescheduleSchedulerAnchorDate = new Date();
                }
            }
        });
    </script>

    <script>
        (function () {
            var doctorBlockTimes = @Html.Raw(Json.Serialize(Model.Doctorblocktime));
            var holidays = @Html.Raw(Json.Serialize(Model.Holidays));
            var doctorLeaves = @Html.Raw(Json.Serialize(Model.Leaves));
            var appointmentSlotScheduleInited = false;

            /** Bootstrap md and below: Day; wider: Week (matches common phone/tablet portrait breakpoints). */
            function appointmentSlotScheduleDefaultView() {
                return window.matchMedia('(max-width: 767.98px)').matches ? 'Day' : 'Week';
            }

            /**
             * Syncfusion Week view renders continuation days of a multi-day timed event in the all-day header.
             * Split each merged span into one event per local calendar day, clipped to visible work hours,
             * so every blocked day shows a full column in the time grid (matches startHour/endHour on the Schedule).
             */
            function splitMergedIntervalIntoWorkdaySegments(interval, workStartH, workStartM, workEndH, workEndM) {
                var segments = [];
                var start = interval.start instanceof Date ? interval.start : new Date(interval.start);
                var end = interval.end instanceof Date ? interval.end : new Date(interval.end);
                if (isNaN(start.getTime()) || isNaN(end.getTime()) || end.getTime() <= start.getTime()) {
                    return segments;
                }
                var cursor = new Date(start.getFullYear(), start.getMonth(), start.getDate());
                var endDay = new Date(end.getFullYear(), end.getMonth(), end.getDate());
                while (cursor.getTime() <= endDay.getTime()) {
                    var workStart = new Date(cursor.getFullYear(), cursor.getMonth(), cursor.getDate(), workStartH, workStartM, 0, 0);
                    var workEnd = new Date(cursor.getFullYear(), cursor.getMonth(), cursor.getDate(), workEndH, workEndM, 0, 0);
                    var segStart = start.getTime() > workStart.getTime() ? start : workStart;
                    var segEnd = end.getTime() < workEnd.getTime() ? end : workEnd;
                    if (segStart.getTime() < segEnd.getTime()) {
                        segments.push({ start: new Date(segStart), end: new Date(segEnd) });
                    }
                    cursor.setDate(cursor.getDate() + 1);
                }
                return segments;
            }

            /**
             * Merge overlapping or nearly-touching intervals (gapMs absorbs API sub-second / rounding gaps).
             */
            function mergeDateIntervals(intervals, gapMs) {
                gapMs = gapMs == null ? 120000 : gapMs;
                if (!intervals || !intervals.length) return [];
                var valid = [];
                for (var i = 0; i < intervals.length; i++) {
                    var iv = intervals[i];
                    if (!iv || !iv.start || !iv.end) continue;
                    var s = iv.start instanceof Date ? iv.start : new Date(iv.start);
                    var e = iv.end instanceof Date ? iv.end : new Date(iv.end);
                    if (isNaN(s.getTime()) || isNaN(e.getTime())) continue;
                    if (e.getTime() <= s.getTime()) {
                        e = new Date(s.getTime() + 15 * 60 * 1000);
                    }
                    valid.push({ start: s, end: e });
                }
                valid.sort(function (a, b) { return a.start - b.start; });
                var out = [];
                for (var j = 0; j < valid.length; j++) {
                    var cur = valid[j];
                    if (!out.length) {
                        out.push({ start: new Date(cur.start), end: new Date(cur.end) });
                        continue;
                    }
                    var last = out[out.length - 1];
                    if (cur.start.getTime() <= last.end.getTime() + gapMs) {
                        if (cur.end.getTime() > last.end.getTime()) last.end = new Date(cur.end);
                    } else {
                        out.push({ start: new Date(cur.start), end: new Date(cur.end) });
                    }
                }
                return out;
            }

            function intervalsFromDoctorBlocks(items) {
                var list = [];
                if (!items || !items.length) return list;
                for (var i = 0; i < items.length; i++) {
                    var item = items[i];
                    var startRaw = item.procedureScheduleDateTime != null ? item.procedureScheduleDateTime : item.ProcedureScheduleDateTime;
                    var endRaw = item.procedureScheduleEndDateTime != null ? item.procedureScheduleEndDateTime : item.ProcedureScheduleEndDateTime;
                    if (startRaw == null) continue;
                    var s = new Date(startRaw);
                    if (isNaN(s.getTime())) continue;
                    var e = endRaw != null ? new Date(endRaw) : null;
                    if (!e || isNaN(e.getTime()) || e.getTime() <= s.getTime()) {
                        e = new Date(s.getTime() + 15 * 60 * 1000);
                    }
                    list.push({ start: s, end: e });
                }
                return list;
            }

            function portalAppointmentSchedulerDataUrl() {
                var params = new URLSearchParams(window.location.search);
                params.set('handler', 'SchedulerData');
                return window.location.pathname + '?' + params.toString();
            }

            function paintAppointmentSlotScheduleBlocks(scheduleObj) {
                var selectedDoctorId = 1;
                var doctorLeaveSlots = (doctorLeaves || [])
                    .filter(function (x) { return Number(x.doctorId) === Number(selectedDoctorId); })
                    .map(function (x) {
                        return {
                            start: new Date(x.startDateTime),
                            end: new Date(x.endDateTime || x.startDateTime)
                        };
                    });
                window.calendarDoctorLeaveSlots = doctorLeaveSlots;

                var holidayDates = (holidays || []).map(function (item) {
                    return new Date(item.startDate).toISOString().split('T')[0];
                });

                var blockIntervals = intervalsFromDoctorBlocks(doctorBlockTimes);
                var leaveIntervals = doctorLeaveSlots.map(function (slot) {
                    return { start: slot.start, end: slot.end };
                });
                var mergedAll = mergeDateIntervals(blockIntervals.concat(leaveIntervals), 120000);
                var blockAppointments = [];
                mergedAll.forEach(function (m, idx) {
                    splitMergedIntervalIntoWorkdaySegments(m, 10, 0, 19, 15).forEach(function (seg, j) {
                        blockAppointments.push({
                            Id: 'busy-day-' + idx + '-' + j + '-' + seg.start.getTime(),
                            Subject: 'Not available',
                            StartTime: seg.start,
                            EndTime: seg.end,
                            IsReadonly: true,
                            CategoryColor: '#7AB6E0'
                        });
                    });
                });

                scheduleObj.renderCell = function (args) {
                    if (args.elementType === 'workCells' || args.elementType === 'monthCells') {
                        var cellDate = args.date.toISOString().split('T')[0];
                        if (holidayDates.includes(cellDate)) {
                            args.element.classList.add('e-disabled', 'holiday-cell');
                        }
                        if (Array.isArray(window.calendarDoctorLeaveSlots)) {
                            var inLeave = window.calendarDoctorLeaveSlots.some(function (slot) {
                                return args.date >= slot.start && args.date < slot.end;
                            });
                            if (inLeave) {
                                args.element.classList.add('e-disabled', 'doctor-leave-cell');
                            }
                        }
                    }
                };

                scheduleObj.eventSettings.dataSource = blockAppointments;
                if (typeof scheduleObj.refreshEvents === "function") {
                    scheduleObj.refreshEvents();
                } else {
                    scheduleObj.refresh();
                }
            }

            function initAppointmentSlotSchedule() {
                if (appointmentSlotScheduleInited) return;
                var scheduleEl = document.getElementById('appointmentSlotSchedule');
                if (!scheduleEl || !scheduleEl.ej2_instances || !scheduleEl.ej2_instances[0]) return;
                appointmentSlotScheduleInited = true;
                var scheduleObj = scheduleEl.ej2_instances[0];
                scheduleObj.currentView = appointmentSlotScheduleDefaultView();
                paintAppointmentSlotScheduleBlocks(scheduleObj);
                scheduleObj.popupOpen = function (args) {
                    if (args.type === 'Editor' && args.data.Id === undefined) {
                        args.cancel = true;
                    }
                };

                var slotModalEl = document.getElementById('appointmentSlotModal');
                if (slotModalEl) {
                    slotModalEl.addEventListener('shown.bs.modal', function () {
                        var loader = document.getElementById('appointmentSlotModalScheduleLoader');
                        function showSchedLoader() {
                            if (loader) {
                                loader.classList.add('is-active');
                                loader.setAttribute('aria-busy', 'true');
                            }
                        }
                        function hideSchedLoader() {
                            if (loader) {
                                loader.classList.remove('is-active');
                                loader.setAttribute('aria-busy', 'false');
                            }
                        }

                        var el = document.getElementById('appointmentSlotSchedule');
                        if (!el || !el.ej2_instances || !el.ej2_instances[0]) return;
                        var inst = el.ej2_instances[0];
                        showSchedLoader();

                        function finishLayout(onDone) {
                            inst.currentView = appointmentSlotScheduleDefaultView();
                            if (window.__patientRescheduleSchedulerAnchorDate) {
                                inst.selectedDate = new Date(window.__patientRescheduleSchedulerAnchorDate);
                                window.__patientRescheduleSchedulerAnchorDate = null;
                            }
                            inst.refresh();
                            if (typeof inst.refreshLayout === 'function') {
                                setTimeout(function () {
                                    inst.refreshLayout();
                                    if (onDone) {
                                        setTimeout(onDone, 60);
                                    }
                                }, 100);
                            } else if (onDone) {
                                setTimeout(onDone, 80);
                            }
                        }

                        fetch(portalAppointmentSchedulerDataUrl(), { credentials: 'same-origin', headers: { 'Accept': 'application/json' } })
                            .then(function (r) { return r.ok ? r.json() : Promise.reject(); })
                            .then(function (data) {
                                doctorBlockTimes = data.doctorBlocks || [];
                                holidays = data.holidays || [];
                                doctorLeaves = data.leaves || [];
                                paintAppointmentSlotScheduleBlocks(inst);
                                finishLayout(hideSchedLoader);
                            })
                            .catch(function () {
                                finishLayout(hideSchedLoader);
                            });
                    });
                    slotModalEl.addEventListener('hidden.bs.modal', function () {
                        hideSchedLoader();
                    });
                }
            }

            var slotScheduleTries = 0;
            function tryInitSlotSchedule() {
                initAppointmentSlotSchedule();
                if (!appointmentSlotScheduleInited && slotScheduleTries++ < 120) {
                    setTimeout(tryInitSlotSchedule, 80);
                }
            }

            window.addEventListener('load', function () {
                tryInitSlotSchedule();
            });
        })();

        function onAppointmentSlotCellClick(args) {
            args.cancel = true;
            var clickedDateTime = new Date(args.startTime);
            if (typeof window.portalValidateAppointmentSlotClickTime === "function") {
                if (!window.portalValidateAppointmentSlotClickTime(clickedDateTime)) return;
            }
            if (clickedDateTime.getDay() === 0) {
                return;
            }
            if (Array.isArray(window.calendarDoctorLeaveSlots)) {
                var inLeave = window.calendarDoctorLeaveSlots.some(function (slot) {
                    return clickedDateTime >= slot.start && clickedDateTime < slot.end;
                });
                if (inLeave) return;
            }

            var dtpEl = document.getElementById('pi-resched');
            if (dtpEl && dtpEl.ej2_instances && dtpEl.ej2_instances[0]) {
                dtpEl.ej2_instances[0].value = clickedDateTime;
                dtpEl.ej2_instances[0].dataBind();
            }

            var modalEl = document.getElementById('appointmentSlotModal');
            if (modalEl && typeof bootstrap !== 'undefined') {
                var inst = bootstrap.Modal.getInstance(modalEl);
                if (!inst) inst = bootstrap.Modal.getOrCreateInstance(modalEl);
                inst.hide();
            }
        }
    </script>
                </div>
            </main>
        </div>
    </div>
</body>


