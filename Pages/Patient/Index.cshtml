            <script>
                document.addEventListener("DOMContentLoaded", function () {
                    const countryValuee = "@Model.PatientData.Country";
                    const stateValuee = "@Model.PatientData.State";
                    const cityValuee = "@Model.PatientData.City";

                    if (countryValuee) {
                        onCountryChange({ value: countryValuee }, false, stateValuee, cityValuee);
                    }
                });

                async function onCountryChange(args, shouldReset = true, selectedState = null, selectedCity = null) {
                    var countryId = args.value;

                    const stateDropdown = document.getElementById('stateDropdown').ej2_instances[0];
                    const cityDropdown = document.getElementById('cityDropdown').ej2_instances[0];
                    const countryDropdown = document.getElementById('countryDropdown')?.ej2_instances?.[0];
                    const selectedCountryText = countryDropdown?.text ?? "";

                    // Set or clear * for State and City based on Country
                    // if (selectedCountryText.toLowerCase() === "india") {
                    //     $('#stateRequired').text('*');
                    //     $('#cityRequired').text('*');
                    // } else {
                    //     $('#stateRequired').text('');
                    //     $('#cityRequired').text('');
                    // }
                    if (shouldReset) {
                        stateDropdown.value = null;
                        stateDropdown.dataSource = [];
                        stateDropdown.refresh();

                        cityDropdown.value = null;
                        cityDropdown.dataSource = [];
                        cityDropdown.refresh();
                    }

                    if (!countryId) {
                        stateDropdown.dataSource = [];
                        stateDropdown.value = null;
                        stateDropdown.refresh();
                        cityDropdown.dataSource = [];
                        cityDropdown.value = null;
                        cityDropdown.refresh();
                        return;
                    }

                    try {
                        const response = await fetch(`/Patient?handler=States&countryId=${countryId}`);
                        const states = await response.json();

                        stateDropdown.dataSource = states;
                        stateDropdown.refresh();

                        if (selectedState) {
                            stateDropdown.value = selectedState;
                            stateDropdown.refresh();
                            // Now fetch cities for selected state
                            await onStateChange({ value: selectedState }, false, selectedCity);
                        }
                    } catch (error) {
                        console.error('Error fetching states:', error);
                    }
                }

                async function onStateChange(args, shouldReset = true, selectedCity = null) {
                    var stateId = args.value;
                    const cityDropdown = document.getElementById('cityDropdown').ej2_instances[0];

                    if (shouldReset) {
                        cityDropdown.value = null;
                        cityDropdown.dataSource = [];
                        cityDropdown.refresh();
                    }

                    if (!stateId) {
                        cityDropdown.dataSource = [];
                        cityDropdown.value = null;
                        cityDropdown.refresh();
                        return;
                    }

                    try {
                        const response = await fetch(`/Patient?handler=Cities&stateId=${stateId}`);
                        const cities = await response.json();

                        cityDropdown.dataSource = cities;
                        cityDropdown.refresh();

                        if (selectedCity) {
                            cityDropdown.value = selectedCity;
                            cityDropdown.refresh();
                        }
                    } catch (error) {
                        console.error('Error fetching cities:', error);
                    }
                }

            </script>


            <script>
                function portalSetRowContextFromRowData(rowData) {
                    var hidReq = document.getElementById("PortalRowIsAppointmentRequest");
                    var hidPid = document.getElementById("PortalRowPatientId");
                    if (!hidReq || !hidPid || !rowData) return;
                    var isReq = rowData.isAppointmentRequest === true || rowData.isAppointmentRequest === "true";
                    hidReq.value = isReq ? "true" : "false";
                    var pid = rowData.patientId != null && rowData.patientId !== "" ? rowData.patientId : rowData.PatientId;
                    hidPid.value = (pid !== undefined && pid !== null && pid !== "") ? String(pid) : "";
                }
                function portalSetRowContextFromCard(card) {
                    var hidReq = document.getElementById("PortalRowIsAppointmentRequest");
                    var hidPid = document.getElementById("PortalRowPatientId");
                    if (!hidReq || !hidPid || !card) return;
                    var inpReq = card.querySelector("input[name='portalIsAppointmentRequest']");
                    var inpPid = card.querySelector("input[name='portalPatientId']");
                    hidReq.value = (inpReq && inpReq.value === "true") ? "true" : "false";
                    hidPid.value = (inpPid && inpPid.value) ? inpPid.value : "";
                }
                document.addEventListener("DOMContentLoaded", function () {
                    // Event delegation for dynamically generated elements
                    document.body.addEventListener("click", function (event) {
                        let rescheduleBtn = event.target.closest(".app-resched");
                        let cancelBtn = event.target.closest("[data-bs-target='#app-cancel']");

                        if (rescheduleBtn) {
                            let appointmentId;

                            // Check if clicked inside the grid or a dynamically generated card
                            let row = rescheduleBtn.closest("tr");
                            if (row && document.getElementById("GridPatientAppointments")) {
                                let grid = document.getElementById("GridPatientAppointments").ej2_instances[0];
                                let rowData = grid.getRowInfo(row).rowData;
                                appointmentId = rowData.id ?? rowData.Id;
                                portalSetRowContextFromRowData(rowData);
                            } else {
                                // Handle dynamically generated card
                                let card = rescheduleBtn.closest(".ius-gridrow");
                                if (card) {
                                    appointmentId = card.querySelector("input[name='appointmentId']").value;
                                    portalSetRowContextFromCard(card);
                                }
                            }

                            // Set the appointmentId value in the hidden field inside the Reschedule Modal
                            // Do not use truthiness: API may send Id 0 before server maps LeadId; 0 is valid only after mapping.
                            if (appointmentId !== undefined && appointmentId !== null && appointmentId !== "") {
                                document.getElementById("AppoinmentId").value = appointmentId;
                            }
                        }

                        if (cancelBtn) {
                            let appointmentId;

                            // Check if clicked inside the grid or a dynamically generated card
                            let row = cancelBtn.closest("tr");
                            if (row && document.getElementById("GridPatientAppointments")) {
                                let grid = document.getElementById("GridPatientAppointments").ej2_instances[0];
                                let rowData = grid.getRowInfo(row).rowData;
                                appointmentId = rowData.id ?? rowData.Id;
                                portalSetRowContextFromRowData(rowData);
                            } else {
                                // Handle dynamically generated card
                                let card = cancelBtn.closest(".ius-gridrow");
                                if (card) {
                                    appointmentId = card.querySelector("input[name='appointmentId']").value;
                                    portalSetRowContextFromCard(card);
                                }
                            }

                            // Set the appointmentId value in the hidden field inside the Cancel Modal
                            if (appointmentId !== undefined && appointmentId !== null && appointmentId !== "") {
                                document.getElementById("CancelPatientId").value = appointmentId;
                            }
                        }
                    });
                });
            </script>

            <script>

                document.addEventListener("DOMContentLoaded", function () {
                    var ageInput = document.getElementById("pi-age");
                    var dobPicker = document.getElementById("pi-dob").ej2_instances[0]; // Syncfusion Datepicker instance

                    // Age se Date of Birth calculate karna
                    ageInput.addEventListener("input", function () {
                        var age = parseInt(this.value, 10);
                        var today = new Date();

                        if (!isNaN(age) && age > 0) {
                            var birthYear = today.getFullYear() - age;
                            var birthDate = new Date(birthYear, today.getMonth(), today.getDate());
                            dobPicker.value = birthDate; // Syncfusion Datepicker me set karna
                        } else if (age === 0) {
                            var yesterday = new Date();
                            yesterday.setDate(today.getDate() - 1); // Today - 1 day
                            dobPicker.value = yesterday; // DOB me ek din pehle ka date set karna
                        }
                    });

                    // Date of Birth se Age calculate karna
                    dobPicker.addEventListener("input", function () {
                        updateAge();
                    });

                    dobPicker.addEventListener("change", function () {
                        updateAge();
                    });

                    function updateAge() {
                        var dob = dobPicker.value;
                        if (dob) {
                            var today = new Date();
                            var birthDate = new Date(dob);
                            var age = today.getFullYear() - birthDate.getFullYear();

                            // Agar DOB ke month aur date aaj ke month aur date se aage hain, toh age -1 karna
                            var monthDiff = today.getMonth() - birthDate.getMonth();
                            if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < birthDate.getDate())) {
                                age--;
                            }

                            ageInput.value = age; // Age input ko update karna
                        }
                    }
                });
            </script>

            <script>
                function onQueryCellInfo(args) {
                    var statusField = args.column.field;
                    if (statusField === "statusName" || statusField === "StatusName") {
                        if (args.data.statusName === "Booked") {
                            args.cell.innerHTML = `<span class="badge badge-success">Booked</span>`;
                        } else if (args.data.statusName === "Completed") {
                            args.cell.innerHTML = `<span class="badge badge-Primary">Completed</span>`;
                        } else if (args.data.statusName === "Converted to Appt." || args.data.statusName === "Converted To Appointment") {
                            args.cell.innerHTML = `<span class="badge badge-Primary">Converted to Appt.</span>`;
                        } else if (args.data.statusName === "Request Rejected") {
                            args.cell.innerHTML = `<span class="badge badge-danger">Request Rejected</span>`;
                        }
                        else if (args.data.statusName === "Request Sent") {
                            args.cell.innerHTML = `<span class="badge badge-secondary">Request Sent</span>`;
                        }
                        else if (args.data.statusName === "Confirmed") {
