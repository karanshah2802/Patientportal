                var seconds = parseInt(parts[5], 10);
                var ampm = parts[6];

                if (ampm === 'PM' && hours < 12) hours += 12;
                if (ampm === 'AM' && hours === 12) hours = 0;

                return new Date(yyyy, MM, dd, hours, minutes, seconds);
            }

        });

    </script>
