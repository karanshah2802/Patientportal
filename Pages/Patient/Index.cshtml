            // Validate Age
            var ageValue = $("#pi-age").val().trim();
            if (ageValue === "") {
                $("#agevalidation").text("Age is required.");
                isValid = false;
            } else if (isNaN(ageValue) || ageValue < 0 || ageValue > 99) {
                $("#agevalidation").text("Invalid Age."); 
                isValid = false;
            } else {
                $("#agevalidation").text("");
            }
            var dobValue = $("#pi-dob").val().trim();
            if (dobValue === "") {
                $("#dobvalidation").text("Date of Birth is required.");
                isValid = false;
            } else {
                var dobDate = new Date(dobValue.split('/').reverse().join('-')); // Convert dd/MM/yyyy to yyyy-MM-dd
                var currentDate = new Date();
                currentDate.setFullYear(currentDate.getFullYear()); // Subtract 1 year from today
                var minDate = new Date();
                minDate.setFullYear(currentDate.getFullYear() - 100); // Minimum 99 years allowed

                if (dobDate > currentDate) {
                    $("#dobvalidation").text("Invalid Date of Birth.");
                    isValid = false;
                } else if (dobDate < minDate) {
                    $("#dobvalidation").text("Invalid Date of Birth.");
                    isValid = false;
                }
                else if (dobDate == "Invalid Date") {
                    $("#dobvalidation").text("Invalid Date of Birth.");
                    isValid = false;
                }
                else {
                    $("#dobvalidation").text("");
                }
            }
            // Validate Gender
            var selectedGender = $("input[name='gender']:checked").val();
            if (!selectedGender) {
                $("#GenderValidation").text("Gender is required.");
                isValid = false;
            } else {
                $("#GenderValidation").text("");
            }

            // Validate Marital Status
            // if ($("#pi-matstat").val() === null || $("#pi-matstat").val() === "") {
            //     $("#MaritalStatusValidation").text("Marital Status is required.");
            //     isValid = false;
            // } else {
            //     $("#MaritalStatusValidation").text("");
            // }

            // If any validation fails, stop AJAX request
            if (!isValid) {
                $button.prop("disabled", false).text("Save");
                return;
            }
            var genderMapping = {
                "gender-male": "Male",
                "gender-female": "Female",
                "gender-other": "Other"
            };

            var multiselectObj = document.getElementById("pincodedropdown").ej2_instances[0];
            var selectedGenderId = $("input[name='gender']:checked").attr("id");
