        function loadSchedulerData2(schedulerId) {
            debugger;
            var doctorBlockTimes = @Html.Raw(Json.Serialize(Model.Doctorblocktime));
            var holidays = @Html.Raw(Json.Serialize(Model.Holidays));
            var doctorLeaves = @Html.Raw(Json.Serialize(Model.Leaves)); // <-- ADD THIS

            var selectedDoctorId = 1;
            var holidayDates = holidays.map(function (item) {
                var d = new Date(item.startDate);
                return d.getFullYear() + "-" +
                    String(d.getMonth() + 1).padStart(2, '0') + "-" +
                    String(d.getDate()).padStart(2, '0');
            });

            var doctorLeaveSlots = doctorLeaves
                .filter(x => x.doctorId === selectedDoctorId)
                .map(function (x) {
                    return {
                        start: new Date(x.startDateTime),
                        end: new Date(x.endDateTime || x.startDateTime)
                    };
                });
            console.log("Holiday Dates:", holidayDates);
            console.log("Doctor Leave Slots:", doctorLeaveSlots);
            // Global for second scheduler click blocking
            window.patientDoctorLeaveSlots2 = doctorLeaveSlots;

            if (!doctorBlockTimes || doctorBlockTimes.length === 0) {
                console.log("No blocked appointments found.");
                return;
            } else {
                console.log("Blocked Appointments:", doctorBlockTimes);
            }

            setTimeout(function () {
                var scheduleObj = document.getElementById(schedulerId)?.ej2_instances?.[0];

                if (!scheduleObj) {
                    console.error("Scheduler instance not found.");
                    return;
                }
                scheduleObj.renderCell = function (args) {
                    if (args.elementType === "workCells" || args.elementType === "monthCells") {
                        var cellDate = args.date.toISOString().split('T')[0]; // Get YYYY-MM-DD format
                        if (holidayDates.includes(cellDate)) {
                            args.element.classList.add("e-disabled", "holiday-cell"); // Apply custom class
                        }
                        // Doctor 1 leave slots -> gray within time range
                        if (Array.isArray(window.patientDoctorLeaveSlots2)) {
                            var inLeave = window.patientDoctorLeaveSlots2.some(function (slot) {
                                return args.date >= slot.start && args.date < slot.end;
                            });
                            if (inLeave) {
                                args.element.classList.add("e-disabled", "doctor-leave-cell");
                            }
                        }
                    }
                };
                // Convert data to Scheduler format
                var blockAppointments = doctorBlockTimes.map(function (item) {
                    var isPatientAppointment = item.isPatientAppointment === true;

                    return {
                        Id: item.id,
                        Subject: isPatientAppointment ? 'Your Appointment' : 'Not available', // Change subject
                        StartTime: new Date(item.procedureScheduleDateTime),
                        EndTime: new Date(item.procedureScheduleEndDateTime),
                        IsReadonly: true,
                        CategoryColor: isPatientAppointment ? '#28a745' : '#0061AB'  // Green for patient, Red for normal
                    };
                });
