    <script>
        let selectedScheduleDate = null;

        // Capture AppointmentStartTime + 7 days on reschedule button click
        document.addEventListener("click", function (e) {
            const target = e.target.closest(".app-resched");
            if (target && target.dataset.starttime) {
                const originalDate = new Date(target.dataset.starttime);
                const today = new Date();
                today.setHours(0, 0, 0, 0); // Normalize to midnight

                const appointmentDate = new Date(originalDate);
                appointmentDate.setHours(0, 0, 0, 0); // Normalize to midnight

                if (appointmentDate >= today) {
                    originalDate.setDate(originalDate.getDate() + 7); // future or today -> +7 days
                    selectedScheduleDate = originalDate;
                } else {
                    selectedScheduleDate = new Date(); // past -> use today
                }
            }
        });

        document.addEventListener("DOMContentLoaded", function () {
            $('#schedulerModal').on('shown.bs.modal', function () {
                loadSchedulerData(); // Modal open hone par function call hoga
            });
        });

        function loadSchedulerData() {
            var doctorBlockTimes = @Html.Raw(Json.Serialize(Model.Doctorblocktime));
            var holidays = @Html.Raw(Json.Serialize(Model.Holidays));
            var doctorLeaves = @Html.Raw(Json.Serialize(Model.Leaves)); // <-- ADD THIS

            var selectedDoctorId = 1;
            var holidayDates = holidays.map(function (item) {
                var d = new Date(item.startDate);
                return d.getFullYear() + "-" +
                    String(d.getMonth() + 1).padStart(2, '0') + "-" +
                    String(d.getDate()).padStart(2, '0');
            });

            var doctorLeaveSlots = doctorLeaves
                .filter(x => x.doctorId === selectedDoctorId)
                .map(function (x) {
                    return {
                        start: new Date(x.startDateTime),
                        end: new Date(x.endDateTime || x.startDateTime)
                    };
                });
            console.log("Holiday Dates:", holidayDates);
            console.log("Doctor Leave Slots:", doctorLeaveSlots);
            // Global for main scheduler click blocking
            window.patientDoctorLeaveSlots = doctorLeaveSlots;
            var holidayDates = holidays.map(function (item) {
                return new Date(item.startDate).toISOString().split('T')[0];
            });

            if (!doctorBlockTimes || doctorBlockTimes.length === 0) {
                console.log("No blocked appointments found.");
                return;
            } else {
                console.log("Blocked Appointments:", doctorBlockTimes);
            }

            setTimeout(function () {
                var scheduleObj = document.getElementById('schedulerss')?.ej2_instances?.[0];

                if (!scheduleObj) {
                    console.error("Scheduler instance not found.");
                    return;
                }

                // Set the selected date to 7 days after clicked appointment time
                if (selectedScheduleDate) {
                    scheduleObj.selectedDate = new Date(); // Current date
                    scheduleObj.dataBind(); // Apply the selected date
                }


                // Mark holidays
                scheduleObj.renderCell = function (args) {
                    if (args.elementType === "workCells" || args.elementType === "monthCells") {
                        var cellDate = args.date.toISOString().split('T')[0];
                        if (holidayDates.includes(cellDate)) {
                            args.element.classList.add("e-disabled", "holiday-cell");
                        }
                        // Doctor 1 leave slots -> gray within time range
                        if (Array.isArray(window.patientDoctorLeaveSlots)) {
                            var inLeave = window.patientDoctorLeaveSlots.some(function (slot) {
                                return args.date >= slot.start && args.date < slot.end;
                            });
                            if (inLeave) {
                                args.element.classList.add("e-disabled", "doctor-leave-cell");
                            }
                        }
                    }
                };

                // Convert to scheduler-compatible event data
                var blockAppointments = doctorBlockTimes.map(function (item) {
                    var isPatientAppointment = item.isPatientAppointment === true;

                    return {
                        Id: item.id,
                        Subject: isPatientAppointment ? 'Your Appointment' : 'Not available',
                        StartTime: new Date(item.procedureScheduleDateTime),
                        EndTime: new Date(item.procedureScheduleEndDateTime),
                        IsReadonly: true,
                        CategoryColor: isPatientAppointment ? '#28a745' : '#0061AB'
                    };
                });
                // Block only leave time range (not full day)
                doctorLeaveSlots.forEach(function (slot) {
                    blockAppointments.push({
                        Id: "LV-" + slot.start.toISOString(),
                        Subject: "Doctor Leave",
                        StartTime: slot.start,
                        EndTime: slot.end,
                        IsReadonly: true,
                        CategoryColor: "#ff0000"  // Red color for leave block
                    });
                });
                console.log("Final Event Data for Scheduler:", blockAppointments);

                scheduleObj.eventSettings.dataSource = [];
                scheduleObj.refresh();

                scheduleObj.eventSettings.template = function (data) {
                    var subject = data.Subject || '';
                    var color = data.CategoryColor || '#0061AB';
                    return `<div class="blocked-slot2" style="background-color:${color}; color:white; text-align:center;">${subject}</div>`;
                };

                setTimeout(() => {
                    scheduleObj.eventSettings.dataSource = blockAppointments;
                    scheduleObj.refresh();
                }, 300);

            }, 500);
        }
    </script>


