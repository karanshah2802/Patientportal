    <script>
        function loadSchedulerData2(schedulerId) {
            var params = new URLSearchParams(window.location.search);
            params.set('handler', 'SchedulerData');
            var url = window.location.pathname + '?' + params.toString();
            var selectedDoctorId = 1;
            var loader = document.getElementById('patientSchedulerModal2Loader');
            function hideModal2Loader() {
                if (loader) {
                    loader.classList.remove('is-active');
                    loader.setAttribute('aria-busy', 'false');
                }
            }
            if (loader) {
                loader.classList.add('is-active');
                loader.setAttribute('aria-busy', 'true');
            }

            setTimeout(function () {
                var scheduleObj = document.getElementById(schedulerId)?.ej2_instances?.[0];
                if (!scheduleObj) {
                    console.error("Scheduler instance not found.");
                    hideModal2Loader();
                    return;
                }

                fetch(url, { credentials: 'same-origin', headers: { 'Accept': 'application/json' } })
                    .then(function (r) { return r.ok ? r.json() : Promise.reject(); })
                    .then(function (data) {
                        var doctorBlockTimes = data.doctorBlocks || [];
                        var holidays = data.holidays || [];
                        var doctorLeaves = data.leaves || [];

                        var built = window.patientRescheduleScheduleApi.buildPatientRescheduleBlockAppointments(
                            doctorBlockTimes, doctorLeaves, selectedDoctorId);
                        var blockAppointments = built.blockAppointments;
                        var doctorLeaveSlots = built.doctorLeaveSlots;

                        window.patientDoctorLeaveSlots2 = doctorLeaveSlots;

                        var holidayDates = (holidays || []).map(function (item) {
                            return new Date(item.startDate).toISOString().split('T')[0];
                        });

                        scheduleObj.currentView = window.patientRescheduleScheduleApi.patientRescheduleScheduleDefaultView();
                        scheduleObj.selectedDate = new Date();
                        scheduleObj.showAllDayPanel = false;

                        scheduleObj.renderCell = function (args) {
                            if (args.elementType === "workCells" || args.elementType === "monthCells") {
                                var cellDate = args.date.toISOString().split('T')[0];
                                if (holidayDates.includes(cellDate)) {
                                    args.element.classList.add("e-disabled", "holiday-cell");
                                }
                                if (Array.isArray(window.patientDoctorLeaveSlots2)) {
                                    var inLeave = window.patientDoctorLeaveSlots2.some(function (slot) {
                                        return args.date >= slot.start && args.date < slot.end;
                                    });
                                    if (inLeave) {
                                        args.element.classList.add("e-disabled", "doctor-leave-cell");
                                    }
                                }
                            }
                        };

                        scheduleObj.eventSettings.dataSource = blockAppointments;
                        scheduleObj.popupOpen = function (args) {
                            if (args.type === 'Editor' && args.data.Id === undefined) {
                                args.cancel = true;
                            }
                        };
                        scheduleObj.dataBind();
                        if (typeof scheduleObj.refreshEvents === 'function') {
                            scheduleObj.refreshEvents();
                        }
                        if (typeof scheduleObj.refreshLayout === 'function') {
                            scheduleObj.refreshLayout();
                        }
                        if (window.innerWidth <= 768) {
                            scheduleObj.timeScale = { enable: true, interval: 15, slotCount: 1 };
                            scheduleObj.currentView = 'Day';
                            if (typeof scheduleObj.refreshLayout === 'function') {
                                scheduleObj.refreshLayout();
                            }
                        }
                        setTimeout(hideModal2Loader, 80);
                    })
                    .catch(function () {
                        console.error("Failed to refresh scheduler data.");
                        hideModal2Loader();
                    });
            }, 500);
        }

        // Prevents quick popup opening
        function onPopupOpen(args) {
            if (args.type === "QuickInfo") {
                args.cancel = true;
            }
        }



        document.addEventListener('DOMContentLoaded', function () {
            var scheduleObj2 = document.getElementById('schedulerss2').ej2_instances[0];

            if (scheduleObj2) {
                scheduleObj2.popupOpen = function (args) {
                    if (args.type === "Editor" && args.data.Id === undefined) {
