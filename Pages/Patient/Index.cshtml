    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        (function (w) {
            function portalAppointmentParseJsonBody(xhr) {
                var txt = xhr.responseText;
                if (txt && txt.charCodeAt(0) === 0xfeff) txt = txt.slice(1);
                var trimmed = txt ? String(txt).trim() : "";
                if (trimmed.length > 0 && (trimmed.charAt(0) === "{" || trimmed.charAt(0) === "[")) {
                    try {
                        return JSON.parse(trimmed);
                    } catch (e) {
                        /* fall through to responseJSON */
                    }
                }
                if (xhr.responseJSON) return xhr.responseJSON;
                return null;
            }
            function portalAppointmentCoalesceHumanMessage(j) {
                function nz(v) {
                    if (v == null) return null;
                    var s = String(v).trim();
                    return s ? s : null;
                }
                if (!j) return null;
                var m = nz(j.message) || nz(j.Message) || nz(j.errorMessage) || nz(j.ErrorMessage)
                    || nz(j.description) || nz(j.Description) || nz(j.detail) || nz(j.Detail)
                    || nz(j.title) || nz(j.Title);
                if (m) return m;
                var errs = j.errors || j.Errors;
                if (!errs) return null;
                if (Array.isArray(errs) && errs.length) {
                    var p = [];
                    for (var i = 0; i < errs.length; i++) {
                        var t = nz(errs[i]);
                        if (t) p.push(t);
                    }
                    return p.length ? p.join(" ") : null;
                }
                if (typeof errs === "object") {
                    var p2 = [];
                    for (var k in errs) {
                        if (!Object.prototype.hasOwnProperty.call(errs, k)) continue;
                        var v = errs[k];
                        if (Array.isArray(v)) {
                            for (var ii = 0; ii < v.length; ii++) {
                                var t2 = nz(v[ii]);
                                if (t2) p2.push(t2);
                            }
                        } else {
                            var t3 = nz(v);
                            if (t3) p2.push(t3);
                        }
                    }
                    return p2.length ? p2.join(" ") : null;
                }
                return null;
            }
            w.portalAppointmentMessageFromJsonResult = function (r) {
                return portalAppointmentCoalesceHumanMessage(r)
                    || (r && (String(r.errorMessage || r.ErrorMessage || "").trim() || null));
            };
            w.portalAppointmentParseError = function (xhr) {
                var j = portalAppointmentParseJsonBody(xhr);
                if (!j) return { errorCode: null, message: null, errors: null, minimumLeadHours: null };
                var human = portalAppointmentCoalesceHumanMessage(j);
                var rawEc = j.errorCode != null ? j.errorCode : (j.ErrorCode != null ? j.ErrorCode : (j.error && (j.error.code != null ? j.error.code : j.error.Code)));
                var errorCodeStr = rawEc == null || rawEc === "" ? null : String(rawEc);
                return {
                    errorCode: errorCodeStr,
                    message: human,
                    errors: j.errors || j.Errors || null,
                    minimumLeadHours: j.minimumLeadHours != null ? j.minimumLeadHours : (j.MinimumLeadHours != null ? j.MinimumLeadHours : null)
                };
            };
            w.portalAppointmentFormatErrors = function (b) {
                if (!b || !b.errors) return null;
                if (Array.isArray(b.errors) && b.errors.length) return b.errors.join(" ");
                if (typeof b.errors === "object") {
                    var parts = [];
                    for (var k in b.errors) {
                        if (!Object.prototype.hasOwnProperty.call(b.errors, k)) continue;
                        var v = b.errors[k];
                        if (Array.isArray(v)) parts = parts.concat(v);
                        else if (v) parts.push(String(v));
                    }
                    return parts.length ? parts.join(" ") : null;
                }
                return null;
            };
            w.portalAppointmentHandleHttpError = function (xhr, opts) {
                opts = opts || {};
                var $span = opts.$span;
                var onDone = opts.onDone;
                function finish() { if (typeof onDone === "function") onDone(); }
                function clearInline() {
                    if ($span && $span.length) $span.text("");
                }
                function showGeneric(msg) {
                    clearInline();
                    if (typeof toastr !== "undefined") toastr.error(msg);
                    else alert(msg);
                    finish();
                }
                if (xhr.status !== 400) {
                    var parsed = w.portalAppointmentParseError(xhr);
                    var msg = parsed.message || w.portalAppointmentFormatErrors(parsed)
                        || (xhr.responseText && xhr.responseText.length < 400 ? String(xhr.responseText).trim() : null)
                        || "Request failed.";
                    showGeneric(msg);
                    return;
                }
                var b = w.portalAppointmentParseError(xhr);
                var code = b.errorCode;
                var text = b.message || w.portalAppointmentFormatErrors(b)
                    || (xhr.responseText && xhr.responseText.length < 400 ? String(xhr.responseText).trim() : null)
                    || "Request could not be completed.";
                if (code === "APPOINTMENT_MINIMUM_LEAD_TIME") {
                    clearInline();
                    if (typeof toastr !== "undefined") toastr.warning(text);
                    else alert(text);
                    finish();
                    return;
                }
                if (code === "APPOINTMENT_TIME_REQUIRED") {
                    clearInline();
                    if (typeof toastr !== "undefined") toastr.info(text);
                    else alert(text);
                    finish();
                    return;
                }
                if (code === "PATIENT_PORTAL_RESCHEDULE_LIMIT_REACHED") {
                    clearInline();
                    if (typeof toastr !== "undefined") toastr.warning(text);
                    else alert(text);
                    finish();
                    return;
                }
                showGeneric(text);
            };
            w.portalNotifySlotPick = function (msg) {
                if (typeof toastr !== "undefined") toastr.warning(msg);
                else alert(msg);
            };
            w.portalValidateAppointmentSlotClickTime = function (clickedDateTime) {
                var now = new Date();
                if (clickedDateTime < now) {
                    w.portalNotifySlotPick("This time is in the past. Please choose a future date and time.");
                    return false;
                }
                if (clickedDateTime.getTime() - now.getTime() < 60 * 60 * 1000) {
                    w.portalNotifySlotPick("Appointment must be at least one hour from now.");
                    return false;
                }
                return true;
            };
        })(window);
