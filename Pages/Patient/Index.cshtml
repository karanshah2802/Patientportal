<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    var MOBILE_APPT_PAGE_SIZE = 15;
    var mobileApptPageIndex = 0;
    var mobileApptTotalCount = 0;

    function formatAppointmentCardDateTime(dateString) {
        if (!dateString) return 'N/A';
        const date = new Date(dateString);
        if (isNaN(date.getTime())) return 'N/A';
        let day = String(date.getDate()).padStart(2, '0');
        let month = String(date.getMonth() + 1).padStart(2, '0');
        let year = date.getFullYear();
        let hours = date.getHours();
        let minutes = String(date.getMinutes()).padStart(2, '0');
        let seconds = String(date.getSeconds()).padStart(2, '0');
        let ampm = hours >= 12 ? 'PM' : 'AM';
        hours = hours % 12;
        hours = hours ? hours : 12;
        hours = String(hours).padStart(2, '0');
        return `${day}/${month}/${year} ${hours}:${minutes}:${seconds} ${ampm}`;
    }

    function updateAppointmentPager() {
        var pager = $("#appointments-pager");
        var total = mobileApptTotalCount || 0;
        if (total === 0 || total <= MOBILE_APPT_PAGE_SIZE) {
            pager.addClass("d-none");
            return;
        }
        pager.removeClass("d-none");
        var totalPages = Math.ceil(total / MOBILE_APPT_PAGE_SIZE);
        var currentPage = mobileApptPageIndex + 1;
        $("#appt-pager-info").text("Page " + currentPage + " of " + totalPages);
        $("#appt-pager-prev").prop("disabled", mobileApptPageIndex <= 0);
        $("#appt-pager-next").prop("disabled", mobileApptPageIndex >= totalPages - 1);
    }

    $(document).ready(function () {
        loadAppointments();
        $(document).on("click", "#appt-pager-prev", function () {
            if (mobileApptPageIndex > 0) {
                loadAppointments(mobileApptPageIndex - 1);
            }
        });
        $(document).on("click", "#appt-pager-next", function () {
            var totalPages = Math.ceil(mobileApptTotalCount / MOBILE_APPT_PAGE_SIZE);
            if (mobileApptPageIndex < totalPages - 1) {
                loadAppointments(mobileApptPageIndex + 1);
            }
        });
    });

    function loadAppointments(pageIndex) {
        if (typeof pageIndex === "number" && !isNaN(pageIndex)) {
            mobileApptPageIndex = pageIndex;
        }
        var skip = mobileApptPageIndex * MOBILE_APPT_PAGE_SIZE;
        $.ajax({
            url: '/Patient/Index?handler=AppointmentViewCard&id=' + '@Model.Id',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify({ skip: skip, take: MOBILE_APPT_PAGE_SIZE }),
            success: function (response) {
                mobileApptTotalCount = typeof response.count === "number" ? response.count : 0;
                var appointments = response.result || [];
                var container = $("#appointments-container");
                container.empty();

                if (appointments.length === 0) {
                    updateAppointmentPager();
                    return;
                }

                $.each(appointments, function (index, appointment) {
                    var badgeClass = "";
                    if (appointment.statusName === "Booked" || appointment.statusName === "Completed" || appointment.statusName === "Converted to Appt.") {
                        badgeClass = "badge-green";
                    } else if (appointment.statusName === "Cancelled" || appointment.statusName === "Request Rejected") {
                        badgeClass = "badge-red";
                    }
                    var startLabel = formatAppointmentCardDateTime(appointment.appointmentStartTime);
                    var cardHtml = `
                                <div class="ius-gridrow">
                                    <div class="ius-appbody">
                                        <div class="ius-appinfo">
                                            <input type="hidden" name="appointmentId" value="${appointment.id}">

                                                        <h3>${appointment.doctorName || 'N/A'}</h3>
                                            ${(appointment.bookedForPatientName || appointment.patientName || appointment.name) ? `<div class="text-12 text-muted mt-1">For: ${appointment.bookedForPatientName || appointment.patientName || appointment.name}</div>` : ''}
                                            <div class="ius-apptyfo">
                                                        <span class="appinfo-type">${appointment.appoinmentType || 'N/A'}</span>
                                                <span class="appinfo-dot"></span>
                                            </div>
                                        </div>

                                        <div class="ius-ctrls">
                                                         ${appointment.statusName !== "Cancelled" && appointment.statusName !== "Check-In" && appointment.statusName !== "Completed" && appointment.statusName !== "Converted to Appt." && appointment.statusName !== "Request Rejected" && appointment.appoinmentType !== "Dr. Sejal Online Consultation" && appointment.appoinmentType !== "Appointment Request for Procedures" ? `
                                                <a href="#schedulerModal" class="app-resched" title="Reschedule" data-bs-toggle="modal" data-bs-target="#schedulerModal">
                                                         <img loading="lazy" src="@Url.Content("~/assets/calendar.svg")" width="18" height="20" alt="Calendar">

                                            </a>
                                            <a href="#app-cancel" title="Cancel" data-bs-toggle="modal" data-bs-target="#app-cancel">
                                                            <img loading="lazy" src="@Url.Content("~/assets/delete.svg")" width = "18" height = "20" alt = "Cancel" >
                                            </a>

                                                ` : ''}

                                        </div>
                                    </div>
                                    <div class="ius-foo">
                                        <div class="ius-datetime">
                                            <div class="datetime-label text-sb">Date & Time</div>
                                                    <div>${startLabel || 'N/A'}</div>
                                        </div>
                                        <div class="ius-status">
                                             <div class="ius-badge ${badgeClass}">${appointment.statusName || 'N/A'}</div>
                                        </div>
                                    </div>
                                </div>
                            `;
                    container.append(cardHtml);
                });
                updateAppointmentPager();
            },
            error: function (xhr, status, error) {
                console.error("Error fetching appointments: ", error);
            }
        });
    }

</script>
