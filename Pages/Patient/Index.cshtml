    <script>
        function roundToNearest15(date) {
            const interval = 15 * 60 * 1000; // 15 minutes
            return new Date(Math.round(date.getTime() / interval) * interval);
        }

        document.addEventListener('DOMContentLoaded', function () {

            const pickerEl = document.getElementById("pi-resched");
            if (!pickerEl || !pickerEl.ej2_instances) return;

            const picker = pickerEl.ej2_instances[0];
            let isInternalUpdate = false;

            picker.change = function (args) {
                if (!args.value || isInternalUpdate) return;

                const rounded = roundToNearest15(new Date(args.value));

                if (+rounded !== +args.value) {
                    isInternalUpdate = true;
                    picker.value = rounded;
                    picker.dataBind();
                    isInternalUpdate = false;
                }
            };
        });
    </script>
