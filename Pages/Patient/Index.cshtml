                var customPincode = $("#custompincode").val().trim();
                if (!customPincode) {
                    $("#custompincodeValidation").text("Pincode is required.");
                    isValid = false;
                } else {
                    var selectedText = customPincode.toString() ?? "";

                    var pincodePattern = /^[0-9]{6}$/;
