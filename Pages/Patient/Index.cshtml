            // Fix: Extract single value from array (Multiselect returns array even with maxSelectionLength=1)
            var selectedPincodeId = multiselectObj.value;
            var PincodeId = null;
            
            // Check if custom pincode is being used
            var isCustomPincodeVisible = $("#customPincodeDiv").is(":visible");
            
            if (isCustomPincodeVisible) {
                // If custom pincode is visible, set PincodeId to null (custom pincode will be used)
                PincodeId = null;
            } else {
                // Extract single value from array if it's an array
                if (Array.isArray(selectedPincodeId)) {
                    if (selectedPincodeId.length > 0) {
                        PincodeId = selectedPincodeId[0];
                    } else {
                        PincodeId = null;
                    }
                } else if (selectedPincodeId !== null && selectedPincodeId !== undefined && selectedPincodeId !== "") {
                    // If it's already a single value, use it directly
                    PincodeId = selectedPincodeId;
                } else {
                    PincodeId = null;
                }
            }
            
            // Ensure PincodeId is a number or null (not undefined or empty string)
            if (PincodeId === "" || PincodeId === undefined) {
                PincodeId = null;
            } else if (PincodeId !== null) {
                PincodeId = parseInt(PincodeId, 10);
                if (isNaN(PincodeId)) {
                    PincodeId = null;
                }
            }

// Get Locality
            var localityValue = $("#customlocality").val().trim();

            var stateObj = document.getElementById("stateDropdown").ej2_instances[0];
            var stateId = stateObj.value;

            var countryObj = document.getElementById("countryDropdown").ej2_instances[0];
            var countryId = countryObj.value;
            var formData = {
                Name: $("#pi-name").val(),
                Id: $("#PatientId").val(),
                Email: $("#pi-email").val(),
                Age: $("#pi-age").val(),
                Dob: formattedDob, // Use formatted date
                Gender: selectedGender, // Get selected gender
                MaritalStatus: $("#pi-matstat").val(),
                Address: $("#pi-address").val(),
                City: cityId,
                PincodeId :PincodeId,
                Pincode : custompincode,
                Locality :localityValue,
                State: stateId,
                Country: countryId
            };

            // Function to convert date to MM/DD/YYYY
            function formatDateToMMDDYYYY(dateString) {
                if (!dateString) return "";

                var parts = dateString.split("/"); // Assuming input format is DD/MM/YYYY
                if (parts.length === 3) {
                    return `${parts[1]}/${parts[0]}/${parts[2]}`; // Convert to MM/DD/YYYY
                }
                return dateString; // Return original if format is unknown
            }


            $.ajax({
                url: "/Patient/Index?handler=SavePatient",
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(formData),
                success: function (response) {
                    localStorage.setItem("showPatientSuccessMessage", "true"); // Set flag before reload
                    location.reload(); // Reload page
                },
                error: function (xhr) {
                    alert("Error: " + xhr.responseText);
                }
            });
        });
