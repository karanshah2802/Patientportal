            <script>
                document.addEventListener("DOMContentLoaded", function () {
                    const countryValuee = "@Model.PatientData.Country";
                    const stateValuee = "@Model.PatientData.State";
                    const cityValuee = "@Model.PatientData.City";

                    if (countryValuee) {
                        onCountryChange({ value: countryValuee }, false, stateValuee, cityValuee);
                    }
                });

                async function onCountryChange(args, shouldReset = true, selectedState = null, selectedCity = null) {
                    var countryId = args.value;

                    const stateDropdown = document.getElementById('stateDropdown').ej2_instances[0];
                    const cityDropdown = document.getElementById('cityDropdown').ej2_instances[0];
                    const countryDropdown = document.getElementById('countryDropdown')?.ej2_instances?.[0];
                    const selectedCountryText = countryDropdown?.text ?? "";

                    // Set or clear * for State and City based on Country
                    // if (selectedCountryText.toLowerCase() === "india") {
                    //     $('#stateRequired').text('*');
                    //     $('#cityRequired').text('*');
                    // } else {
                    //     $('#stateRequired').text('');
                    //     $('#cityRequired').text('');
                    // }
                    if (shouldReset) {
                        stateDropdown.value = null;
                        stateDropdown.dataSource = [];
                        stateDropdown.refresh();

                        cityDropdown.value = null;
                        cityDropdown.dataSource = [];
                        cityDropdown.refresh();
                    }

                    if (!countryId) {
                        stateDropdown.dataSource = [];
                        stateDropdown.value = null;
                        stateDropdown.refresh();
                        cityDropdown.dataSource = [];
                        cityDropdown.value = null;
                        cityDropdown.refresh();
                        return;
                    }

                    try {
                        const response = await fetch(`/Patient?handler=States&countryId=${countryId}`);
                        const states = await response.json();

                        stateDropdown.dataSource = states;
                        stateDropdown.refresh();

                        if (selectedState) {
                            stateDropdown.value = selectedState;
                            stateDropdown.refresh();
                            // Now fetch cities for selected state
                            await onStateChange({ value: selectedState }, false, selectedCity);
                        }
                    } catch (error) {
                        console.error('Error fetching states:', error);
                    }
                }

                async function onStateChange(args, shouldReset = true, selectedCity = null) {
                    var stateId = args.value;
                    const cityDropdown = document.getElementById('cityDropdown').ej2_instances[0];

                    if (shouldReset) {
                        cityDropdown.value = null;
                        cityDropdown.dataSource = [];
                        cityDropdown.refresh();
                    }

                    if (!stateId) {
                        cityDropdown.dataSource = [];
                        cityDropdown.value = null;
                        cityDropdown.refresh();
                        return;
                    }

                    try {
                        const response = await fetch(`/Patient?handler=Cities&stateId=${stateId}`);
                        const cities = await response.json();

                        cityDropdown.dataSource = cities;
                        cityDropdown.refresh();

                        if (selectedCity) {
                            cityDropdown.value = selectedCity;
                            cityDropdown.refresh();
                        }
                    } catch (error) {
                        console.error('Error fetching cities:', error);
                    }
                }

            </script>


