    <script>
        (function () {
            function splitMergedIntervalIntoWorkdaySegments(interval, workStartH, workStartM, workEndH, workEndM) {
                var segments = [];
                var start = interval.start instanceof Date ? interval.start : new Date(interval.start);
                var end = interval.end instanceof Date ? interval.end : new Date(interval.end);
                if (isNaN(start.getTime()) || isNaN(end.getTime()) || end.getTime() <= start.getTime()) {
                    return segments;
                }
                var cursor = new Date(start.getFullYear(), start.getMonth(), start.getDate());
                var endDay = new Date(end.getFullYear(), end.getMonth(), end.getDate());
                while (cursor.getTime() <= endDay.getTime()) {
                    var workStart = new Date(cursor.getFullYear(), cursor.getMonth(), cursor.getDate(), workStartH, workStartM, 0, 0);
                    var workEnd = new Date(cursor.getFullYear(), cursor.getMonth(), cursor.getDate(), workEndH, workEndM, 0, 0);
                    var segStart = start.getTime() > workStart.getTime() ? start : workStart;
                    var segEnd = end.getTime() < workEnd.getTime() ? end : workEnd;
                    if (segStart.getTime() < segEnd.getTime()) {
                        segments.push({ start: new Date(segStart), end: new Date(segEnd) });
                    }
                    cursor.setDate(cursor.getDate() + 1);
                }
                return segments;
            }

            function mergeDateIntervals(intervals, gapMs) {
                gapMs = gapMs == null ? 120000 : gapMs;
                if (!intervals || !intervals.length) return [];
                var valid = [];
                for (var i = 0; i < intervals.length; i++) {
                    var iv = intervals[i];
                    if (!iv || !iv.start || !iv.end) continue;
                    var s = iv.start instanceof Date ? iv.start : new Date(iv.start);
                    var e = iv.end instanceof Date ? iv.end : new Date(iv.end);
                    if (isNaN(s.getTime()) || isNaN(e.getTime())) continue;
                    if (e.getTime() <= s.getTime()) {
                        e = new Date(s.getTime() + 15 * 60 * 1000);
                    }
                    valid.push({ start: s, end: e });
                }
                valid.sort(function (a, b) { return a.start - b.start; });
                var out = [];
                for (var j = 0; j < valid.length; j++) {
                    var cur = valid[j];
                    if (!out.length) {
                        out.push({ start: new Date(cur.start), end: new Date(cur.end) });
                        continue;
                    }
                    var last = out[out.length - 1];
                    if (cur.start.getTime() <= last.end.getTime() + gapMs) {
                        if (cur.end.getTime() > last.end.getTime()) last.end = new Date(cur.end);
                    } else {
                        out.push({ start: new Date(cur.start), end: new Date(cur.end) });
                    }
                }
                return out;
            }

            function intervalsFromDoctorBlocks(items) {
                var list = [];
                if (!items || !items.length) return list;
                for (var i = 0; i < items.length; i++) {
                    var item = items[i];
                    var startRaw = item.procedureScheduleDateTime != null ? item.procedureScheduleDateTime : item.ProcedureScheduleDateTime;
                    var endRaw = item.procedureScheduleEndDateTime != null ? item.procedureScheduleEndDateTime : item.ProcedureScheduleEndDateTime;
                    if (startRaw == null) continue;
                    var s = new Date(startRaw);
                    if (isNaN(s.getTime())) continue;
                    var e = endRaw != null ? new Date(endRaw) : null;
                    if (!e || isNaN(e.getTime()) || e.getTime() <= s.getTime()) {
                        e = new Date(s.getTime() + 15 * 60 * 1000);
                    }
                    list.push({ start: s, end: e });
                }
                return list;
            }

            function patientRescheduleScheduleDefaultView() {
                return window.matchMedia('(max-width: 767.98px)').matches ? 'Day' : 'Week';
            }

            function buildPatientRescheduleBlockAppointments(doctorBlockTimes, doctorLeaves, selectedDoctorId) {
                selectedDoctorId = selectedDoctorId == null ? 1 : selectedDoctorId;
                var doctorLeaveSlots = (doctorLeaves || [])
                    .filter(function (x) { return Number(x.doctorId) === Number(selectedDoctorId); })
                    .map(function (x) {
                        return {
                            start: new Date(x.startDateTime),
                            end: new Date(x.endDateTime || x.startDateTime)
                        };
                    });
                var blockIntervals = intervalsFromDoctorBlocks(doctorBlockTimes || []);
                var leaveIntervals = doctorLeaveSlots.map(function (slot) {
                    return { start: slot.start, end: slot.end };
                });
                var mergedAll = mergeDateIntervals(blockIntervals.concat(leaveIntervals), 120000);
                var blockAppointments = [];
                mergedAll.forEach(function (m, idx) {
                    splitMergedIntervalIntoWorkdaySegments(m, 10, 0, 19, 15).forEach(function (seg, j) {
                        blockAppointments.push({
                            Id: 'busy-day-' + idx + '-' + j + '-' + seg.start.getTime(),
                            Subject: 'Not available',
                            StartTime: seg.start,
                            EndTime: seg.end,
                            IsReadonly: true,
                            CategoryColor: '#7AB6E0'
                        });
                    });
                });
                return { blockAppointments: blockAppointments, doctorLeaveSlots: doctorLeaveSlots };
            }

            window.patientRescheduleScheduleApi = {
                buildPatientRescheduleBlockAppointments: buildPatientRescheduleBlockAppointments,
                patientRescheduleScheduleDefaultView: patientRescheduleScheduleDefaultView
            };
        })();

