<script>
    document.addEventListener("DOMContentLoaded", function () {
        let editBtn = document.getElementById("edit-btn");
        let saveBtn = document.getElementById("save-btn");
        let cancelBtn = document.getElementById("cancel-btn");

        let fieldsToEnable = [
            "pi-name", "pi-email", "pi-age",
            "gender-male", "gender-female", "gender-other", "pi-matstat", "pi-address","customlocality", "custompincode",
        ];

        function toggleFields(enable) {
            fieldsToEnable.forEach(id => {
                let field = document.getElementById(id);
                if (field) {
                    if (field.type === "radio") {
                        field.disabled = !enable;
                    } else {
                        field.readOnly = !enable;
                    }
                }
            });

            // ✅ Syncfusion Dropdown Readonly/Enable Logic
            let maritalDropdown = document.getElementById("pi-matstat").ej2_instances[0];
            if (maritalDropdown) {
                maritalDropdown.enabled = enable;
            }
            let PincodeDropdown = document.getElementById("pincodedropdown").ej2_instances[0];
            if (PincodeDropdown) {
                PincodeDropdown.enabled = enable;
                // When enabling, ensure value is properly set and displayed
                if (enable) {
                    setTimeout(function() {
                        // Get patient data
                        var patientPincodeId = "@Model.PatientData.PincodeId";
                        var patientPincode = "@Model.PatientData.Pincode";
                        var patientLocality = "@Model.PatientData.Locality";
                        
                        // Check if custom pincode should be shown
                        if (patientPincode && patientPincode.trim() !== "" && patientPincode !== "0") {
                            // Show custom pincode, hide dropdown
                            document.getElementById("customPincodeDiv").style.display = "block";
                            document.getElementById("referencePincodeDiv").style.display = "none";
                            var customPincodeInput = document.getElementById("custompincode");
                            customPincodeInput.value = patientPincode;
                            // Enable custom pincode field in edit mode
                            customPincodeInput.readOnly = false;
                            if (patientLocality && patientLocality.trim() !== "") {
                                document.getElementById("customlocality").value = patientLocality;
                            }
                        } else if (patientPincodeId && patientPincodeId.trim() !== "" && patientPincodeId !== "0") {
                            // Show dropdown with selected pincode
                            var pincodeIdNum = parseInt(patientPincodeId, 10);
                            if (!isNaN(pincodeIdNum) && pincodeIdNum > 0) {
                                // Get current value
                                var currentValue = PincodeDropdown.value;
                                
                                // Set value as array (multiselect requirement)
                                var shouldSetValue = true;
                                if (Array.isArray(currentValue) && currentValue.length > 0) {
                                    if (currentValue[0] === pincodeIdNum || currentValue[0] == pincodeIdNum) {
                                        shouldSetValue = false;
                                    }
                                }
                                
                                if (shouldSetValue) {
                                    PincodeDropdown.value = [pincodeIdNum];
                                }
                                
                                // Ensure dropdown is visible
                                document.getElementById("referencePincodeDiv").style.display = "block";
                                document.getElementById("customPincodeDiv").style.display = "none";
                                
                                // Refresh and bind
                                PincodeDropdown.dataBind();
                                PincodeDropdown.refresh();
                                
                                // Set locality if available
                                if (patientLocality && patientLocality.trim() !== "") {
                                    var localityInput = document.getElementById("customlocality");
                                    if (localityInput) {
                                        localityInput.value = patientLocality;
                                    }
                                        } else {
                                            // Try to get locality from pincode data
                                            var pincodeDataLocal = [];
                                            if (PincodeDropdown.dataSource) {
                                                if (Array.isArray(PincodeDropdown.dataSource)) {
                                                    pincodeDataLocal = PincodeDropdown.dataSource;
                                                } else if (PincodeDropdown.dataSource && Array.isArray(PincodeDropdown.dataSource.dataSource)) {
                                                    pincodeDataLocal = PincodeDropdown.dataSource.dataSource;
                                                }
                                            }
                                            
                                            if (pincodeDataLocal.length > 0) {
                                                var selectedPincode = pincodeDataLocal.find(function (item) {
                                                    return item.Id === pincodeIdNum || item.Id == pincodeIdNum || String(item.Id) === String(pincodeIdNum);
                                                });
                                                if (selectedPincode && selectedPincode.LocalityName) {
                                                    var localityInput = document.getElementById("customlocality");
                                                    if (localityInput) {
                                                        localityInput.value = selectedPincode.LocalityName;
                                                    }
                                                }
                                            }
                                        }
                            }
                        }
                    }, 150);
                }
            }   
            let cityDropdown = document.getElementById("cityDropdown").ej2_instances[0];
            if (cityDropdown) {
                cityDropdown.enabled = enable;
            } let stateDropdown = document.getElementById("stateDropdown").ej2_instances[0];
            if (stateDropdown) {
                stateDropdown.enabled = enable;
            } let countryDropdown = document.getElementById("countryDropdown").ej2_instances[0];
            if (countryDropdown) {
                countryDropdown.enabled = enable;
            }

            // ✅ Syncfusion DatePicker Readonly/Enable Logic
            let dobPicker = document.getElementById("pi-dob").ej2_instances[0];
            if (dobPicker) {
                dobPicker.enabled = enable; // Enable/Disable DatePicker
            }

            // ✅ Edit button hide/show logic
            editBtn.style.display = enable ? "none" : "inline-block";

            // ✅ Submit & Cancel buttons show/hide logic
            saveBtn.style.display = enable ? "inline-block" : "none";
            cancelBtn.style.display = enable ? "inline-block" : "none";
        }

        // Initially disable fields and hide Submit & Cancel buttons
        toggleFields(false);

        // Edit button event listener
        editBtn.addEventListener("click", function (event) {
            event.preventDefault();
            toggleFields(true);
        });

        // Cancel button event listener
        cancelBtn.addEventListener("click", function (event) {
            event.preventDefault();
            toggleFields(false);
        });
    });
</script>
