@page
@model Patientportal.Pages.Patient.IndexModel
@using System.Globalization
@using System.Text.Json
@{
    ViewData["Title"] = "Patient Portal";
    Layout = "_LayoutMain";
}
@{

    List<object> toolbarItems = new List<object>();
    toolbarItems.Add("Search");


    List<string> MaritalStatusList = new List<string> { "Single", "Married" };

    var pendingBalance = 0m;

    if (ViewData["Invoice"] != null && decimal.TryParse(ViewData["Invoice"].ToString(), out var value))
    {
        pendingBalance = value;
    }

    var portalDepsProfileIdStr = Model.LoggedInProfileId > 0
        ? Model.LoggedInProfileId.ToString(CultureInfo.InvariantCulture)
        : "0";
    var portalDependentsDmUrl = Model.ShowPortalDependentSection
        ? $"/Appointment/Index?handler=PortalDependents&profileId={portalDepsProfileIdStr}"
        : "";
    var portalDependentsDmUrlJson = JsonSerializer.Serialize(portalDependentsDmUrl);
    var portalDependentsCardUrl = Model.ShowPortalDependentSection
        ? $"/Appointment/Index?handler=PortalDependentsCard&profileId={portalDepsProfileIdStr}"
        : "";
    var portalDependentsCardUrlJson = JsonSerializer.Serialize(portalDependentsCardUrl);
}
@Html.AntiForgeryToken()
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Patient Portal · Inurskn - Patient Portal</title>

    <link rel="stylesheet" href="~/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/css/custom.css">
    <link rel="stylesheet" href="~/css/responsive.css">
    <link rel="stylesheet" href="~/lib/font-awesome/css/all.min.css" />

    <link rel="icon" href="~/favicon.png" type="image/png" asp-append-version="true" />
    <link rel="apple-touch-icon" href="~/favicon.png" asp-append-version="true" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet">

</head>
<body>
    <main class="page">
        <div class="container container-x">
            <h1 class="page-title text-28">Patient Portal</h1>
            <div class="ius-block ius-card ius-appdata">
                <div class="ius-block-head ius-appointment-card-head">
                    <div class="ius-grid-filters">
                        <a class="ius-btn-book-appointment" href="@Url.Page("/Appointment/Index", null, new { fromPatient = "1" })" title="Book appointment">
                            <span>Book appointment</span>
                            <i class="fas fa-arrow-right" aria-hidden="true"></i>
                        </a>
                    </div>

                </div>

                <!-- Only for desktop : Syncfusion -->
                <div class="ius-table d-none d-lg-block table-responsive">
                    <ejs-grid id="GridPatientAppointments"
                              allowResizing="true"
                              allowExcelExport="true"
                              allowFiltering="false"
                              allowPaging="true"
                              allowSorting="false"
                              allowSelection="true"
                              allowReordering="true"
                              enableHeaderFocus="true"
                              enablePersistence="false"
                              enableHover="true"
                              autoFit="true"
                              height="200"
                              showColumnChooser="true"
                              rowHeight="38"
                              toolbar=toolbarItems
                              queryCellInfo="onQueryCellInfo"
                              toolbarClick="toolbarClick">

                        <e-data-manager url="/Patient/Index?handler=AppointmentView&Id=@Model.Id" adaptor="UrlAdaptor" crossDomain="true"></e-data-manager>

                        <e-grid-searchsettings fields="@(new string[] {"bookedForPatientName","appoinmentType","doctorName","appointmentStartTime","statusName"})"></e-grid-searchsettings>

                        <e-grid-filtersettings type="Excel"></e-grid-filtersettings>
                        <e-grid-loadingIndicator indicatorType="Shimmer"></e-grid-loadingIndicator>
                        <e-grid-pagesettings pageCount="15" pageSize="15" pageSizes="@(new string[] { "All","12","15","25","50"})"></e-grid-pagesettings>
                        <e-grid-selectionsettings type="Single"></e-grid-selectionsettings>

                        <e-grid-columns>

                            <e-grid-column headerText="Actions" width="120" textAlign="Center" template="#actionTemplate"></e-grid-column>
                            <e-grid-column field="id" headerText="Id" width="200" visible="false" isPrimaryKey="true"></e-grid-column>
                            <e-grid-column field="appoinmentType" headerText="Type of Appointment" width="200"></e-grid-column>
                            <e-grid-column field="bookedForPatientName" headerText="Appointment for" width="180"></e-grid-column>
                            <e-grid-column field="doctorName" headerText="Appointment With" width="200"></e-grid-column>
                            <e-grid-column field="appointmentStartTime" headerText="Appointment Date Time" format="@Model.EjsDateTimePattern" type="dateTime" width="200"></e-grid-column>
                            <e-grid-column field="statusName" headerText="Status" width="150"></e-grid-column>
                        </e-grid-columns>
                    </ejs-grid>
                    <script id="actionTemplate" type="text/x-template">
                        ${if(statusName !== "Cancelled"  && statusName !== "Walked-Out" && statusName !== "Checked-In" && statusName !== "Completed" && statusName !== "Converted to Appt." && statusName !== "Request Rejected" && appoinmentType !== "Appointment Request for Online Consultation" && appoinmentType !== "Dr. Sejal Online Consultation" && appoinmentType !== "Appointment Request for Procedures")}
                                                <a href="#schedulerModal"
                           class="app-resched"
                           title="Reschedule"
                           data-bs-toggle="modal"
                           data-bs-target="#schedulerModal"
                           data-starttime="${appointmentStartTime}">
                            <img loading="lazy" src="@Url.Content("~/assets/calendar.svg")" width="18" height="20" alt="Calendar">
                        </a>
                            <a href="#app-cancel" class="marginleft" title="Cancel" data-bs-toggle="modal" data-bs-target="#app-cancel">
                                <img loading="lazy" src="@Url.Content("~/assets/delete.svg")" width="18" height="20" alt="Cancel">
                            </a>
                        ${/if}
                    </script>

                </div>
            </div>

            @if (Model.ChangeRequests.Count > 0 && Model.ChangeRequests != null)
            {
                <div class="ius-block ius-card ius-notes">
                    <h2 class="mb-2 pb-1 text--red">Changes Requested : Below changes will reflect in your profile after approval from the clinic.</h2>
                    <ol>
                        @foreach (var change in Model?.ChangeRequests)
                        {
                            <li>@change</li>
                        }
                    </ol>
                </div>

            }
            <div class="ius-block ius-card patient-info-card">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 patient-info-card-head">
                    <button class="btn btn-link text-dark text-decoration-none d-flex align-items-center p-0 flex-grow-1 text-start patient-info-collapse-toggle collapsed"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#patientInfoCollapse"
                            aria-expanded="false"
                            aria-controls="patientInfoCollapse">
                        <i class="fas fa-chevron-down patient-info-chevron me-2" aria-hidden="true"></i>
                        <span class="h2 mb-0">Patient Information</span>
                    </button>
                    <a href="#" id="edit-icon" title="Edit Patient Info" class="text-dark flex-shrink-0" style="font-size: 18px;">
                        <i class="fa fa-pencil" aria-hidden="true"></i>
                    </a>
                </div>

                <div class="collapse" id="patientInfoCollapse">
                <form class="ius-form" action="#" method="POST">
                    <input type="hidden" id="PatientId" asp-for="PatientData.Id" name="medicalPatientSignature" class="custom-field-height" />
                    <div class="row">
                        <div class="col-md-6 col-xl-4">
                            <label for="pi-name" class="form-label">Name*</label>
                            <input type="text" name="patientname" maxlength="100" asp-for="PatientData.Name" class="form-control" id="pi-name">
                            <span  id="Namevalidation" asp-validation-for="PatientData.Name" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 col-xl-4">
                            <label for="pi-phoneno" class="form-label">Phone Number*</label>
                            <input type="text" name="phoneno" asp-for="PatientData.Mobile" class="form-control" id="pi-phoneno" disabled>
                            <span id="phonenumbervalidation" asp-validation-for="PatientData.Mobile" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 col-xl-4">
                            <label for="pi-email" class="form-label">Email</label>
                            <input type="email" name="email" asp-for="PatientData.Email" maxlength="100" class="form-control" id="pi-email">
                            <span id="emailvalidation" asp-validation-for="PatientData.Email" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 col-xl-4">
                            <label for="pi-age" class="form-label">Age*</label>
                            <input type="number" name="age" asp-for="PatientData.Age" maxlength="2" class="form-control" id="pi-age">
                            <span id="agevalidation" asp-validation-for="PatientData.Age" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 col-xl-4">
                            <label for="pi-dob" class="form-label">Date of Birth*</label>
                            @* <input type="date" name="dob" class="form-control form-date" id="pi-dob" value="1995-09-03"> *@
                            <ejs-datepicker id="pi-dob" ejs-for="PatientData.Dob" class="form-control" format="dd/MM/yyyy" style="height: 45px;"></ejs-datepicker>
                            <span id="dobvalidation" asp-validation-for="PatientData.Dob" class="text-danger"></span>
                        </div>
                        <script>
                            document.addEventListener("DOMContentLoaded", function () {
                                var dobInput = document.getElementById("pi-dob");

                                dobInput.addEventListener("input", function (e) {
                                    var val = dobInput.value.replace(/\D/g, ""); // Remove non-numeric characters
                                    var formatted = "";

                                    if (val.length > 2) {
                                        formatted += val.substring(0, 2) + "/";
                                        if (val.length > 4) {
                                            formatted += val.substring(2, 4) + "/";
                                            formatted += val.substring(4, 8);
                                        } else {
                                            formatted += val.substring(2);
                                        }
                                    } else {
                                        formatted = val;
                                    }

                                    dobInput.value = formatted;
                                });

                                dobInput.addEventListener("keydown", function (event) {
                                    var allowedKeys = [8, 46]; // Allow backspace and delete
                                    if ((event.keyCode >= 48 && event.keyCode <= 57) ||  // Numbers 0-9
                                        (event.keyCode >= 96 && event.keyCode <= 105) || // Numpad Numbers
                                        allowedKeys.includes(event.keyCode)) {
                                        return true;
                                    }
                                    event.preventDefault(); // Prevent other keys
                                });
                            });
                        </script>
                        <div class="col-md-6 col-xl-4">
                            <label class="form-label">Gender*</label>

                            <div class="btn-group" role="group">
                                <input type="radio" class="btn-check" name="gender" id="gender-male">
                                <label class="btn" for="gender-male">Male</label>

                                <input type="radio" class="btn-check" name="gender" id="gender-female">
                                <label class="btn" for="gender-female">Female</label>

                                <input type="radio" class="btn-check" name="gender" id="gender-other">
                                <label class="btn" for="gender-other">Other</label>
                            </div>
                            <span id="GenderValidation" asp-validation-for="PatientData.Gender" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 col-xl-4">
                            <label for="pi-matstat" class="form-label">Marital Status</label>
                            <ejs-dropdownlist Id="pi-matstat" ejs-for="PatientData.MaritalStatus" style="height: 45px;" class="form-control" TValue="string" DataSource="MaritalStatusList"></ejs-dropdownlist>
                            <span id="MaritalStatusValidation" asp-validation-for="PatientData.MaritalStatus" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 col-xl-4" id="referencePincodeDiv">
                            <label class="form-label">Pincode*</label>
                            <ejs-multiselect id="pincodedropdown"
                                             cssClass="e-multi-column"
                                             mode="Box"
                                             ejs-for="PatientData.PincodeId"
                                             maximumSelectionLength="1"
                                             allowFiltering="true"
                                             filtering="onFiltering"
                                             dataSource="@Model.Pincodes"
                                             change="onPincodeChange">

                                <e-multiselect-fields text="Pincodes" value="Id"></e-multiselect-fields>
                            </ejs-multiselect>

                            <span id="pincodeValidation" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 col-xl-4" id="customPincodeDiv" style="display:none;">
                            <label class="form-label">Pincode*</label>
                            <input asp-for="PatientData.Pincode"
                                   id="custompincode"
                                   type="text"
                                   maxlength="6"
                                   class="form-control"
                                   style="height:45px;">
                            <span id="custompincodeValidation" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 col-xl-4">
                            <label class="form-label">Locality</label>
                            <input asp-for="PatientData.Locality"
                                   id="customlocality"
                                   type="text"
                                   maxlength="50"
                                   class="form-control"
                                   style="height:45px;">
                            <span id="Localityspan" asp-validation-for="PatientData.Locality" class="text-danger"></span>
                        </div>

                        <script>
                            var pincodeData = [];

                            document.addEventListener('DOMContentLoaded', function () {

                                var multiObj = document.getElementById("pincodedropdown").ej2_instances[0];
                                
                                // Get patient data from server
                                var patientPincodeId = "@Model.PatientData.PincodeId";
                                var patientPincode = "@Model.PatientData.Pincode";
                                var patientLocality = "@Model.PatientData.Locality";

                                // 🔹 Templates
                                multiObj.itemTemplate = function (data) {
                                    return `<div>${data.Pincodes} - ${data.LocalityName}</div>`;
                                };

                                multiObj.valueTemplate = function (data) {
                                    return `<div>${data.Pincodes} - ${data.LocalityName}</div>`;
                                };

                                // 🔹 Load datasource once - Get all pincode data
                                var loadPincodeData = function() {
                                    if (multiObj.dataSource && typeof multiObj.dataSource.executeQuery === 'function') {
                                        multiObj.dataSource.executeQuery(new ej.data.Query()).then(function (e) {
                                            pincodeData = e.result || [];
                                            console.log("Pincode data loaded:", pincodeData.length);
                                            // After data is loaded, initialize the selected value
                                            initializePincodeValue();
                                        });
                                    } else {
                                        // If dataSource is an array directly
                                        if (Array.isArray(multiObj.dataSource)) {
                                            pincodeData = multiObj.dataSource;
                                        } else if (multiObj.dataSource && Array.isArray(multiObj.dataSource.dataSource)) {
                                            pincodeData = multiObj.dataSource.dataSource;
                                        }
                                        // Initialize after data is available
                                        setTimeout(initializePincodeValue, 100);
                                    }
                                };

                                // 🔹 Initialize pincode value from patient data
                                function initializePincodeValue() {
                                    // Check if custom pincode exists
                                    if (patientPincode && patientPincode.trim() !== "" && patientPincode !== "0") {
                                        // Show custom pincode input
                                        document.getElementById("customPincodeDiv").style.display = "block";
                                        document.getElementById("referencePincodeDiv").style.display = "none";
                                        var customPincodeInput = document.getElementById("custompincode");
                                        customPincodeInput.value = patientPincode;
                                        
                                        // Disable custom pincode field when it has a value (will be enabled on edit)
                                        customPincodeInput.readOnly = true;
                                        
                                        // Clear multiselect value
                                        multiObj.value = null;
                                        multiObj.dataBind();
                                        
                                        // Set locality if available
                                        if (patientLocality && patientLocality.trim() !== "") {
                                            document.getElementById("customlocality").value = patientLocality;
                                        }
                                    } 
                                    // Check if PincodeId exists (dropdown pincode)
                                    else if (patientPincodeId && patientPincodeId.trim() !== "" && patientPincodeId !== "0") {
                                        var pincodeIdNum = parseInt(patientPincodeId, 10);
                                        
                                        if (!isNaN(pincodeIdNum) && pincodeIdNum > 0) {
                                            // Wait a bit more if pincodeData is still loading
                                            if (pincodeData.length === 0) {
                                                setTimeout(initializePincodeValue, 200);
                                                return;
                                            }
                                            
                                            // Find the pincode in the data
                                            var selectedPincode = pincodeData.find(function (item) {
                                                return item.Id === pincodeIdNum || item.Id == pincodeIdNum || String(item.Id) === String(pincodeIdNum);
                                            });
                                            
                                            if (selectedPincode) {
                                                // Set the value in multiselect (as array since it's multiselect)
                                                multiObj.value = [pincodeIdNum];
                                                multiObj.dataBind();
                                                multiObj.refresh(); // Refresh to ensure value is displayed
                                                
                                                // Auto-fill locality
                                                if (selectedPincode.LocalityName) {
                                                    document.getElementById("customlocality").value = selectedPincode.LocalityName;
                                                } else if (patientLocality && patientLocality.trim() !== "") {
                                                    document.getElementById("customlocality").value = patientLocality;
                                                }
                                                
                                                // Ensure dropdown is visible
                                                document.getElementById("referencePincodeDiv").style.display = "block";
                                                document.getElementById("customPincodeDiv").style.display = "none";
                                                document.getElementById("custompincode").value = "";
                                            } else {
                                                // If pincode not found in data, try to set value anyway (might be server-side binding)
                                                multiObj.value = [pincodeIdNum];
                                                multiObj.dataBind();
                                                multiObj.refresh(); // Refresh to ensure value is displayed
                                                
                                                // Set locality if available
                                                if (patientLocality && patientLocality.trim() !== "") {
                                                    document.getElementById("customlocality").value = patientLocality;
                                                }
                                                
                                                document.getElementById("referencePincodeDiv").style.display = "block";
                                                document.getElementById("customPincodeDiv").style.display = "none";
                                            }
                                        }
                                    }
                                    // If locality exists but no pincode, just set locality
                                    else if (patientLocality && patientLocality.trim() !== "") {
                                        document.getElementById("customlocality").value = patientLocality;
                                    }
                                }

                                // Load pincode data first
                                loadPincodeData();
                                
                                // Also check if value is already set by server-side binding
                                setTimeout(function() {
                                    var currentValue = multiObj.value;
                                    if (currentValue && (Array.isArray(currentValue) ? currentValue.length > 0 : currentValue)) {
                                        // Value is already set, just ensure locality is filled
                                        var selectedId = Array.isArray(currentValue) ? currentValue[0] : currentValue;
                                        if (selectedId) {
                                            var selectedPincode = pincodeData.find(function (item) {
                                                return item.Id === selectedId || item.Id == selectedId || String(item.Id) === String(selectedId);
                                            });
                                            
                                            if (selectedPincode && selectedPincode.LocalityName) {
                                                var localityInput = document.getElementById("customlocality");
                                                if (localityInput && (!localityInput.value || localityInput.value.trim() === "")) {
                                                    localityInput.value = selectedPincode.LocalityName;
                                                }
                                            }
                                        }
                                    }
                                    
                                    // Ensure custom pincode is disabled if it has a value (after initialization)
                                    var customPincodeInput = document.getElementById("custompincode");
                                    if (customPincodeInput && customPincodeInput.value && customPincodeInput.value.trim() !== "") {
                                        customPincodeInput.readOnly = true;
                                    }
                                }, 500);

                                // 🔹 Custom pincode key handling
                                document.getElementById("custompincode").addEventListener("keyup", function () {

                                    var localityInput = document.getElementById("customlocality");

                                    if (this.value.trim() === "") {
                                        document.getElementById("customPincodeDiv").style.display = "none";
                                        document.getElementById("referencePincodeDiv").style.display = "block";
                                        if (localityInput) localityInput.value = "";
                                    } else {
                                        if (localityInput) localityInput.value = "";
                                    }
                                });
                            });

                            // 🔍 Filtering (SEARCH WORKS HERE)
                            function onFiltering(e) {
                                var query = new ej.data.Query();
                                var searchText = e.text || "";

                                // If pincodeData is empty, try to get it from the multiselect instance
                                if (pincodeData.length === 0) {
                                    var multiObj = document.getElementById("pincodedropdown").ej2_instances[0];
                                    if (multiObj) {
                                        if (Array.isArray(multiObj.dataSource)) {
                                            pincodeData = multiObj.dataSource;
                                        } else if (multiObj.dataSource && Array.isArray(multiObj.dataSource.dataSource)) {
                                            pincodeData = multiObj.dataSource.dataSource;
                                        } else if (multiObj.dataSource && typeof multiObj.dataSource.executeQuery === 'function') {
                                            multiObj.dataSource.executeQuery(new ej.data.Query()).then(function (result) {
                                                pincodeData = result.result || [];
                                                applyFilter(e, pincodeData, searchText);
                                            });
                                            return;
                                        }
                                    }
                                }

                                applyFilter(e, pincodeData, searchText);
                            }

                            function applyFilter(e, data, searchText) {
                                var query = new ej.data.Query();

                                if (searchText && searchText.trim() !== "") {
                                    // Convert search text to string for comparison
                                    var searchLower = searchText.toLowerCase().trim();
                                    
                                    // Filter the data manually for better control
                                    var filteredData = data.filter(function (item) {
                                        var pincode = String(item.Pincodes || "").toLowerCase();
                                        var locality = String(item.LocalityName || "").toLowerCase();
                                        return pincode.includes(searchLower) || locality.includes(searchLower);
                                    });

                                    // Update with filtered data
                                    e.updateData(filteredData, query);
                                } else {
                                    // Show all data if no search text
                                    e.updateData(data, query);
                                }

                                setTimeout(function () {
                                    var popup = document.getElementById("pincodedropdown_popup");

                                    if (!searchText || searchText.trim() === "") {
                                        document.getElementById("customPincodeDiv").style.display = "none";
                                        document.getElementById("referencePincodeDiv").style.display = "block";
                                        document.getElementById("custompincode").value = "";
                                    }
                                    else if (popup && popup.querySelector(".e-nodata")) {
                                        document.getElementById("referencePincodeDiv").style.display = "none";
                                        document.getElementById("customPincodeDiv").style.display = "block";

                                        var input = document.getElementById("custompincode");
                                        input.value = searchText;
                                        input.focus();
                                        input.setSelectionRange(input.value.length, input.value.length);

                                        document.getElementById("customlocality").value = "";
                                    }
                                }, 200);
                            }

                            // ✅ Pincode selected → auto-fill locality
                            function onPincodeChange(args) {
                                var localityInput = document.getElementById("customlocality");
                                var selectedValue = args.value;

                                if (selectedValue && selectedValue.length > 0) {
                                    var selectedId = Array.isArray(selectedValue) ? selectedValue[0] : selectedValue;
                                    
                                    // Find the selected pincode data
                                    var selectedPincode = null;
                                    
                                    // Try to get from itemData first
                                    if (args.itemData) {
                                        selectedPincode = args.itemData;
                                    } else {
                                        // Search in pincodeData
                                        if (pincodeData.length === 0) {
                                            var multiObj = document.getElementById("pincodedropdown").ej2_instances[0];
                                            if (multiObj) {
                                                if (Array.isArray(multiObj.dataSource)) {
                                                    pincodeData = multiObj.dataSource;
                                                } else if (multiObj.dataSource && Array.isArray(multiObj.dataSource.dataSource)) {
                                                    pincodeData = multiObj.dataSource.dataSource;
                                                }
                                            }
                                        }
                                        
                                        selectedPincode = pincodeData.find(function (item) {
                                            return item.Id === selectedId || item.Id == selectedId;
                                        });
                                    }

                                    if (selectedPincode) {
                                        document.getElementById("referencePincodeDiv").style.display = "block";
                                        document.getElementById("customPincodeDiv").style.display = "none";
                                        document.getElementById("custompincode").value = "";

                                        if (localityInput) {
                                            localityInput.value = selectedPincode.LocalityName || "";
                                        }
                                    }
                                } else {
                                    // Clear locality if pincode is cleared
                                    if (localityInput) {
                                        localityInput.value = "";
                                    }
                                }
                            }
                        </script>



                       
                        <div class="col-md-6 col-xl-4">
                            <label for="pi-address" class="form-label">Address</label>
                            <textarea type="text" name="address" style="min-height:45px;" asp-for="PatientData.Address" id="pi-address" class="form-control"> </textarea>
                            <span asp-validation-for="PatientData.Address" class="text-danger"></span>

                        </div>
                        <div class="col-md-6 col-xl-4">
                            <label for="pi-country" class="form-label">Country</label>
                            <ejs-dropdownlist id="countryDropdown"
                                              ejs-for="PatientData.Country"
                                              style="height: 45px;"
                                              cssClass="e-multi-column"
                                              popupHeight="300px"
                                              showClearButton="true"
                                              dataSource="@Model.CountryLists"
