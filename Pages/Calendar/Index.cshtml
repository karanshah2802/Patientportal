@page
@model Patientportal.Pages.Calendar.IndexModel
@* @{
    ViewData["Title"] = "Calendar";
    Layout = "_LayoutMainAppoinment";
} *@
<link rel="stylesheet" href="~/css/responsive.css">
<link rel="stylesheet" href="~/css/bootstrap.min.css">
<link rel="stylesheet" href="~/css/custom.css">
<script>
    function portalCalendarSchedulerDataUrl() {
        var params = new URLSearchParams(window.location.search);
        params.set('handler', 'SchedulerData');
        return window.location.pathname + '?' + params.toString();
    }

    function applyCalendarPageSchedule(doctorBlockTimes, holidays, doctorLeaves) {
        doctorBlockTimes = doctorBlockTimes || [];
        holidays = holidays || [];
        doctorLeaves = doctorLeaves || [];
        var scheduleObj = document.getElementById('schedule')?.ej2_instances?.[0];
        if (!scheduleObj) return;

        var selectedDoctorId = 1;
        var holidayDates = holidays.map(function (item) {
            return new Date(item.startDate).toISOString().split('T')[0];
        });

        var doctorLeaveSlots = doctorLeaves
            .filter(function (x) { return x.doctorId === selectedDoctorId; })
            .map(function (x) {
                return {
                    start: new Date(x.startDateTime),
                    end: new Date(x.endDateTime || x.startDateTime)
                };
            });

        window.calendarDoctorLeaveSlots = doctorLeaveSlots;

        var blockAppointments = doctorBlockTimes.map(function (item) {
            var s = item.procedureScheduleDateTime != null ? item.procedureScheduleDateTime : item.ProcedureScheduleDateTime;
            var e = item.procedureScheduleEndDateTime != null ? item.procedureScheduleEndDateTime : item.ProcedureScheduleEndDateTime;
            return {
                Id: item.id,
                Subject: 'Not available',
                StartTime: new Date(s),
                EndTime: new Date(e),
                IsReadonly: true
            };
        });

        scheduleObj.renderCell = function (args) {
            if (args.elementType === "workCells" || args.elementType === "monthCells") {
                var cellDate = args.date.toISOString().split('T')[0];
                if (holidayDates.includes(cellDate)) {
                    args.element.classList.add("e-disabled", "holiday-cell");
                }
                if (Array.isArray(window.calendarDoctorLeaveSlots)) {
                    var inLeave = window.calendarDoctorLeaveSlots.some(function (slot) {
                        return args.date >= slot.start && args.date < slot.end;
                    });
                    if (inLeave) {
                        args.element.classList.add("e-disabled", "doctor-leave-cell");
                    }
                }
            }
        };

        doctorLeaveSlots.forEach(function (slot) {
            blockAppointments.push({
                Id: "LV-" + slot.start.toISOString(),
                Subject: "Doctor Leave",
                StartTime: slot.start,
                EndTime: slot.end,
                IsReadonly: true,
                CategoryColor: "#ff0000"
            });
        });

        scheduleObj.popupOpen = function (args) {
            if (args.type === "Editor" && args.data.Id === undefined) {
                args.cancel = true;
            }
        };

        scheduleObj.eventSettings.dataSource = blockAppointments;
        scheduleObj.refresh();
    }

    function tryInitCalendarFromApi(attempt) {
        attempt = attempt || 0;
        var loader = document.getElementById('calendarPageScheduleLoader');
        var scheduleObj = document.getElementById('schedule')?.ej2_instances?.[0];
        if (!scheduleObj) {
            if (attempt < 100) {
                setTimeout(function () { tryInitCalendarFromApi(attempt + 1); }, 80);
            } else if (loader) {
                loader.classList.remove('is-active');
                loader.setAttribute('aria-busy', 'false');
            }
            return;
        }

        function hideCalendarLoader() {
            if (loader) {
                loader.classList.remove('is-active');
                loader.setAttribute('aria-busy', 'false');
            }
        }

        if (loader) {
            loader.classList.add('is-active');
            loader.setAttribute('aria-busy', 'true');
        }

        fetch(portalCalendarSchedulerDataUrl(), { credentials: 'same-origin', headers: { 'Accept': 'application/json' } })
            .then(function (r) { return r.ok ? r.json() : Promise.reject(); })
            .then(function (data) {
                applyCalendarPageSchedule(data.doctorBlocks, data.holidays, data.leaves);
                if (scheduleObj && typeof scheduleObj.refreshLayout === 'function') {
                    scheduleObj.refreshLayout();
                }
                setTimeout(hideCalendarLoader, 100);
            })
            .catch(function () {
                applyCalendarPageSchedule(
                    @Html.Raw(Json.Serialize(Model.Doctorblocktime)),
                    @Html.Raw(Json.Serialize(Model.Holidays)),
                    @Html.Raw(Json.Serialize(Model.Leaves)));
                if (scheduleObj && typeof scheduleObj.refreshLayout === 'function') {
                    scheduleObj.refreshLayout();
                }
                setTimeout(hideCalendarLoader, 100);
            });
    }

    document.addEventListener("DOMContentLoaded", function () {
        tryInitCalendarFromApi(0);
    });

    window.addEventListener('pageshow', function (ev) {
        if (!ev.persisted) return;
        tryInitCalendarFromApi(0);
    });
</script>

<div class="control-section full-screen-schedule portal-scheduler-loader-wrap">
    <div class="portal-scheduler-loader" id="calendarPageScheduleLoader" role="status" aria-live="polite" aria-busy="false">
        <div class="portal-sched-spinner" aria-hidden="true"></div>
        <span class="portal-scheduler-loader-text">Loading schedule…</span>
    </div>
    <div class="schedule-wrapper">
        <ejs-schedule id="schedule"
                      width="100%" height="100%"
                      selectedDate="DateTime.Today"
                      startHour="10:00" endHour="19:15"
                      allowDragAndDrop="false" allowResizing="false"
                      workDays="new int[] {1, 2, 3, 4, 5, 6}"
                      cellClick="onCellClick">
            <e-schedule-views>
                <e-schedule-view option="Day"></e-schedule-view>
                <e-schedule-view option="Week"></e-schedule-view>
            </e-schedule-views>
            <e-schedule-timescale interval="15" slotCount="1"></e-schedule-timescale>
            <e-schedule-eventsettings dataSource="Model.Doctorblocktime" template="#blockTemplate"></e-schedule-eventsettings>
        </ejs-schedule>
    </div>
</div>

<script>
    function onPopupOpen(args) {
        // Quick popup open hone se rokna
        if (args.type === "QuickInfo") {
            args.cancel = true;
        }
    }
</script>
<script>
    (function (w) {
        if (w.portalValidateAppointmentSlotClickTime) return;
        w.portalNotifySlotPick = function (msg) {
            if (typeof toastr !== "undefined") toastr.warning(msg);
            else alert(msg);
        };
        w.portalValidateAppointmentSlotClickTime = function (clickedDateTime) {
            var now = new Date();
            if (clickedDateTime < now) {
                w.portalNotifySlotPick("This time is in the past. Please choose a future date and time.");
                return false;
            }
            if (clickedDateTime.getTime() - now.getTime() < 60 * 60 * 1000) {
                w.portalNotifySlotPick("Appointment must be at least one hour from now.");
                return false;
            }
            return true;
        };
    })(window);
</script>

<script>
    function onCellClick(args) {
        // Prevent default popup behavior
        args.cancel = true;

        var clickedDateTime = new Date(args.startTime); // Clicked Cell Date & Time

        if (typeof window.portalValidateAppointmentSlotClickTime === "function") {
            if (!window.portalValidateAppointmentSlotClickTime(clickedDateTime)) return;
        }
        var clickedDate = new Date(args.startTime);
        var day = clickedDate.getDay(); // 0 = Sunday

        // Sunday kabhi clickable nahi
        if (day === 0) {
            args.cancel = true;
            return;
        }

        // If clicked time falls inside any Doctor 1 leave slot, block it
        if (Array.isArray(window.calendarDoctorLeaveSlots)) {
            var inLeave = window.calendarDoctorLeaveSlots.some(function (slot) {
                return clickedDateTime >= slot.start && clickedDateTime < slot.end;
            });
            if (inLeave) {
                args.cancel = true;
                return;
            }
        }

        let startTime = args.startTime;

        // Format date without converting to UTC
        let formattedTime = startTime.getFullYear() + "-" +
            ("0" + (startTime.getMonth() + 1)).slice(-2) + "-" +
            ("0" + startTime.getDate()).slice(-2) + "T" +
            ("0" + startTime.getHours()).slice(-2) + ":" +
            ("0" + startTime.getMinutes()).slice(-2) + ":" +
            ("0" + startTime.getSeconds()).slice(-2);

        // Redirect to Appointment page with local time (preserve patient-portal booking flow)
        var fromPatientSuffix = @(Model.ReturnToPatientPortalBooking ? "'&fromPatient=1'" : "''");
        window.location.href = `/Appointment?SelectedDateTime=${formattedTime}` + fromPatientSuffix;
    }


</script>






<!-- Template to show "Book" on blocked slots -->
<script id="blockTemplate" type="text/x-template">
    <div class="blocked-slot">Not available</div>
</script>

<style>
    .blocked-slot {
        color: white;
        text-align: center;
        font-weight: bold;
        padding: 5px;
        border-radius: 5px;
    }

    .e-appointment.e-read-only {
        left: 0 !important;
    }

    .doctor-leave-cell {
        background-color: #e9ecef !important; /* Light red */
        color: #721c24 !important;
        pointer-events: none; /* Disable clicks */
        opacity: 0.6; /* Make it look inactive */
    }

    .schedule-wrapper {
        height: 100vh; /* Full screen height */
        width: 100%; /* Full width */
    }

    .holiday-cell {
        background-color: #dee2e6 !important; /* Light red */
        color: #721c24 !important;
        pointer-events: none; /* Disable clicks */
        opacity: 0.6; /* Make it look inactive */
    }

    .e-appointment.e-read-only {
        width: 100% !important;
    }

    .e-quick-popup-wrapper.e-lib.e-popup.e-control.e-popup-open {
        display: none;
    }

    .e-current-time {
        display: none;
    }

    .e-header-cells {
        pointer-events: none;
    }
</style>
